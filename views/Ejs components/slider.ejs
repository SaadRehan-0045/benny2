<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>BHC Services Cards Slider | Professional Services</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Remixicon Icons -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme transition */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }

        /* Professional Cards Styling - OPTIMIZED FOR MOBILE */
        .service-card-modern {
            background: linear-gradient(145deg, #ffffff, #f8fafc);
            border-radius: 20px;
            padding: 1.5rem 1rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 5px 10px -5px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
            border: 1px solid rgba(37, 99, 235, 0.1);
            position: relative;
            overflow: hidden;
            height: 100%;
            display: flex;
            flex-direction: column;
            width: 100%;
        }
        
        .dark .service-card-modern {
            background: linear-gradient(145deg, #1e293b, #0f172a);
            border-color: rgba(96, 165, 250, 0.15);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3);
        }
        
        .service-card-modern:active {
            transform: scale(0.98);
        }
        
        .card-modern-number {
            font-size: 2.5rem;
            font-weight: 800;
            line-height: 1;
            background: linear-gradient(135deg, #2563eb, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            opacity: 0.25;
            position: absolute;
            top: 0.5rem;
            right: 0.8rem;
            font-family: 'Arial Black', sans-serif;
        }
        
        .dark .card-modern-number {
            background: linear-gradient(135deg, #60a5fa, #93c5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            opacity: 0.3;
        }
        
        .card-modern-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            color: white;
            font-size: 1.6rem;
            box-shadow: 0 8px 15px -5px rgba(37, 99, 235, 0.4);
        }
        
        .dark .card-modern-icon {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            box-shadow: 0 8px 15px -5px rgba(59, 130, 246, 0.3);
        }
        
        .card-modern-title {
            font-size: 1.1rem;
            font-weight: 700;
            line-height: 1.3;
            margin-bottom: 0.5rem;
            color: #1e293b;
            text-transform: uppercase;
            letter-spacing: -0.01em;
            word-break: break-word;
        }
        
        .dark .card-modern-title {
            color: #f1f5f9;
        }
        
        .card-modern-subtitle {
            font-size: 0.75rem;
            color: #64748b;
            margin-bottom: 0.75rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            flex-wrap: wrap;
        }
        
        .dark .card-modern-subtitle {
            color: #94a3b8;
        }
        
        .card-modern-subtitle i {
            color: #2563eb;
            font-size: 0.85rem;
        }
        
        .card-modern-divider {
            width: 40px;
            height: 3px;
            background: linear-gradient(90deg, #2563eb, #60a5fa);
            border-radius: 3px;
            margin: 0.5rem 0 0.75rem 0;
        }
        
        .card-modern-features {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            margin-bottom: 1rem;
            flex: 1;
        }
        
        .card-modern-feature {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.7rem;
            color: #475569;
        }
        
        .dark .card-modern-feature {
            color: #cbd5e1;
        }
        
        .card-modern-feature i {
            color: #2563eb;
            font-size: 0.8rem;
            flex-shrink: 0;
        }
        
        .card-modern-explore {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            color: white;
            padding: 0.6rem 1.2rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            transition: all 0.3s ease;
            margin-top: 0.25rem;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 10px -3px #2563eb;
            text-decoration: none;
            width: fit-content;
            -webkit-tap-highlight-color: transparent;
        }
        
        .card-modern-explore i {
            margin-left: 0.3rem;
            font-size: 0.8rem;
            transition: transform 0.3s ease;
        }
        
        .card-modern-explore:active {
            transform: translateY(-1px);
            box-shadow: 0 6px 15px -3px #2563eb;
        }
        
        .card-modern-explore:active i {
            transform: translateX(3px);
        }
        
        /* Swiper Customization - MOBILE OPTIMIZED */
        .swiper {
            padding: 0.5rem 0.25rem 2rem 0.25rem;
            width: 100%;
            margin: 0 auto;
        }
        
        .swiper-slide {
            height: auto;
            display: flex;
            opacity: 0.9;
            transition: opacity 0.3s ease;
        }
        
        .swiper-slide-active {
            opacity: 1;
        }
        
        .swiper-pagination {
            position: relative;
            margin-top: 1rem;
            bottom: 0 !important;
        }
        
        .swiper-pagination-bullet {
            width: 6px;
            height: 6px;
            background: #2563eb;
            opacity: 0.3;
            transition: all 0.3s ease;
            margin: 0 3px !important;
        }
        
        .swiper-pagination-bullet-active {
            opacity: 1;
            width: 18px;
            border-radius: 4px;
            background: #2563eb;
        }
        
        .dark .swiper-pagination-bullet {
            background: #60a5fa;
        }
        
        /* Hide navigation on mobile, show on desktop */
        .swiper-button-prev,
        .swiper-button-next {
            display: none;
        }
        
        @media (min-width: 1024px) {
            .swiper-button-prev,
            .swiper-button-next {
                display: flex;
                width: 40px;
                height: 40px;
                background: white;
                border-radius: 50%;
                box-shadow: 0 5px 20px -5px rgba(0, 0, 0, 0.2);
                color: #2563eb;
                transition: all 0.3s ease;
            }
            
            .dark .swiper-button-prev,
            .dark .swiper-button-next {
                background: #1e293b;
                color: #60a5fa;
                box-shadow: 0 5px 20px -5px rgba(0, 0, 0, 0.4);
            }
            
            .swiper-button-prev:after,
            .swiper-button-next:after {
                font-size: 1.2rem;
                font-weight: bold;
            }
            
            .swiper-button-prev:hover,
            .swiper-button-next:hover {
                background: #2563eb;
                color: white;
                transform: scale(1.1);
            }
            
            .dark .swiper-button-prev:hover,
            .dark .swiper-button-next:hover {
                background: #3b82f6;
                color: white;
            }
        }
        
        /* Section Header - MOBILE OPTIMIZED */
        .section-header {
            text-align: center;
            margin-bottom: 1.5rem;
            padding: 0 1rem;
        }
        
        .section-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1e293b;
            text-transform: uppercase;
            letter-spacing: -0.02em;
            margin-bottom: 0.35rem;
            line-height: 1.2;
        }
        
        .dark .section-title {
            color: #f1f5f9;
        }
        
        .section-subtitle {
            font-size: 0.75rem;
            color: #64748b;
            max-width: 280px;
            margin: 0 auto;
            line-height: 1.4;
        }
        
        .dark .section-subtitle {
            color: #94a3b8;
        }
        
        .title-highlight {
            color: #2563eb;
            display: inline-block;
        }
        
        .dark .title-highlight {
            color: #60a5fa;
        }
        
        /* Extra Small Devices (phones, 320px and up) */
        @media (min-width: 320px) {
            .service-card-modern {
                padding: 1.2rem 0.8rem;
            }
            
            .card-modern-number {
                font-size: 2.2rem;
                top: 0.4rem;
                right: 0.6rem;
            }
            
            .card-modern-icon {
                width: 45px;
                height: 45px;
                font-size: 1.4rem;
                border-radius: 12px;
            }
            
            .card-modern-title {
                font-size: 1rem;
            }
            
            .card-modern-subtitle {
                font-size: 0.7rem;
            }
            
            .card-modern-feature {
                font-size: 0.65rem;
            }
            
            .card-modern-explore {
                padding: 0.5rem 1rem;
                font-size: 0.65rem;
            }
            
            .section-title {
                font-size: 1.4rem;
            }
        }
        
        /* Small Devices (phones, 375px and up) */
        @media (min-width: 375px) {
            .service-card-modern {
                padding: 1.5rem 1rem;
            }
            
            .card-modern-number {
                font-size: 2.5rem;
            }
            
            .card-modern-title {
                font-size: 1.1rem;
            }
            
            .card-modern-subtitle {
                font-size: 0.75rem;
            }
            
            .card-modern-feature {
                font-size: 0.7rem;
            }
            
            .section-title {
                font-size: 1.5rem;
            }
            
            .section-subtitle {
                font-size: 0.8rem;
                max-width: 300px;
            }
        }
        
        /* Medium Devices (phones, 425px and up) */
        @media (min-width: 425px) {
            .service-card-modern {
                padding: 1.5rem 1.2rem;
            }
            
            .card-modern-icon {
                width: 50px;
                height: 50px;
                font-size: 1.6rem;
            }
            
            .card-modern-title {
                font-size: 1.2rem;
            }
            
            .section-title {
                font-size: 1.6rem;
            }
            
            .section-subtitle {
                max-width: 350px;
            }
        }
        
        /* Tablets */
        @media (min-width: 768px) {
            .service-card-modern {
                padding: 1.8rem 1.2rem;
            }
            
            .card-modern-icon {
                width: 55px;
                height: 55px;
                font-size: 1.8rem;
            }
            
            .card-modern-title {
                font-size: 1.3rem;
            }
            
            .section-title {
                font-size: 2rem;
            }
            
            .section-subtitle {
                font-size: 0.9rem;
                max-width: 500px;
            }
        }
        
        /* Prevent overflow */
        .overflow-x-hidden {
            overflow-x: hidden;
        }
        
        /* Smooth scrolling */
        .swiper-wrapper {
            transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        /* Better touch handling */
        .swiper-slide {
            -webkit-touch-callout: none;
            -webkit-user-select: none;
            user-select: none;
        }
    </style>
</head>


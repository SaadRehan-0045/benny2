    <!-- Initialize Swiper - Mobile Optimized -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var swiper = new Swiper(".mySwiper", {
                // Mobile first configuration
                slidesPerView: 1.2,
                spaceBetween: 12,
                centeredSlides: false,
                loop: true,
                
                // Pagination
                pagination: {
                    el: ".swiper-pagination",
                    clickable: true,
                    dynamicBullets: true,
                    dynamicMainBullets: 5,
                },
                
                // Autoplay - Slower on mobile for better readability
                autoplay: {
                    delay: 4000,
                    disableOnInteraction: true,
                    pauseOnMouseEnter: true,
                },
                
                // Responsive breakpoints
                breakpoints: {
                    // Small phones
                    320: {
                        slidesPerView: 1.1,
                        spaceBetween: 10,
                    },
                    // Regular phones
                    375: {
                        slidesPerView: 1.2,
                        spaceBetween: 12,
                    },
                    // Large phones
                    425: {
                        slidesPerView: 1.3,
                        spaceBetween: 15,
                    },
                    // Tablets
                    640: {
                        slidesPerView: 2,
                        spaceBetween: 15,
                    },
                    768: {
                        slidesPerView: 2,
                        spaceBetween: 18,
                    },
                    // Small desktops
                    1024: {
                        slidesPerView: 3,
                        spaceBetween: 20,
                    },
                    // Large desktops
                    1280: {
                        slidesPerView: 4,
                        spaceBetween: 24,
                    },
                },
                
                // Performance optimizations
                speed: 600,
                grabCursor: true,
                preventClicks: true,
                preventClicksPropagation: true,
                touchRatio: 1.5, // More responsive touch
                resistance: true,
                resistanceRatio: 0.5,
                
                // Keyboard control
                keyboard: {
                    enabled: true,
                    onlyInViewport: true,
                },
                
                // Accessibility
                a11y: {
                    enabled: true,
                    prevSlideMessage: 'Previous slide',
                    nextSlideMessage: 'Next slide',
                },
            });
            
            // Pause autoplay when user interacts
            const swiperContainer = document.querySelector('.swiper');
            swiperContainer.addEventListener('touchstart', function() {
                swiper.autoplay.stop();
            });
            
            swiperContainer.addEventListener('touchend', function() {
                swiper.autoplay.start();
            });
        });
    </script>

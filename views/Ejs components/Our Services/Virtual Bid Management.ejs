<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Virtual Bid Management - Benny Estimates</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        },
                        violet: {
                            50: '#f5f3ff',
                            100: '#ede9fe',
                            200: '#ddd6fe',
                            300: '#c4b5fd',
                            400: '#a78bfa',
                            500: '#8b5cf6',
                            600: '#7c3aed',
                            700: '#6d28d9',
                            800: '#5b21b6',
                            900: '#4c1d95',
                        },
                        cyan: {
                            50: '#ecfeff',
                            100: '#cffafe',
                            200: '#a5f3fc',
                            300: '#67e8f9',
                            400: '#22d3ee',
                            500: '#06b6d4',
                            600: '#0891b2',
                            700: '#0e7490',
                            800: '#155e75',
                            900: '#164e63',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-in-out',
                        'slide-up': 'slideUp 0.3s ease-out',
                        'slide-in-left': 'slideInLeft 0.6s ease-out',
                        'float-tech': 'floatTech 3s ease-in-out infinite',
                        'pulse-digital': 'pulseDigital 2s ease-in-out infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' }
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' }
                        },
                        slideInLeft: {
                            '0%': { opacity: '0', transform: 'translateX(-30px)' },
                            '100%': { opacity: '1', transform: 'translateX(0)' }
                        },
                        floatTech: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-15px)' }
                        },
                        pulseDigital: {
                            '0%, 100%': { boxShadow: '0 0 0 0 rgba(139, 92, 246, 0.4)' },
                            '50%': { boxShadow: '0 0 0 15px rgba(139, 92, 246, 0)' }
                        }
                    }
                }
            }
        }
    </script>
    <style>
        * {
            scrollbar-width: none;
            -ms-overflow-style: none;
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }
        *::-webkit-scrollbar {
            display: none;
        }
        .dark body {
            color-scheme: dark;
        }
        .virtual-card {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            background: linear-gradient(145deg, #ffffff, #f8fafc);
            border: 2px solid #e2e8f0;
            border-radius: 16px;
        }
        .dark .virtual-card {
            background: linear-gradient(145deg, #1f2937, #111827);
            border: 2px solid #374151;
        }
        .virtual-card:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 25px 50px -12px rgba(139, 92, 246, 0.25);
            border-color: #8b5cf6;
        }
        .vbm-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            background: #8b5cf6;
            color: white;
            cursor: pointer;
            z-index: 10;
        }
        .feature-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            cursor: pointer;
        }
        .gradient-text-virtual {
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-weight: 700;
        }
        .plan-card {
            transition: all 0.4s ease;
            border: 3px solid transparent;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }
        .plan-card:hover {
            transform: translateY(-8px);
            border-color: #8b5cf6;
        }
        .plan-card.popular {
            border-color: #8b5cf6;
            box-shadow: 0 20px 25px -5px rgba(139, 92, 246, 0.1);
        }
        .digital-pulse {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100px;
            height: 100px;
            background: radial-gradient(circle, rgba(139, 92, 246, 0.2) 0%, transparent 70%);
            animation: pulseDigital 3s infinite;
            z-index: 0;
        }

        /* SWOT Analysis - New Modern Design */
        .swot-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .swot-card {
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            border: 2px solid transparent;
        }
        
        .swot-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 30px 35px -10px rgba(0, 0, 0, 0.15);
        }
        
        .swot-card.strength {
            background: linear-gradient(145deg, #f0fdf4, #dcfce7);
            border-color: #22c55e;
        }
        .dark .swot-card.strength {
            background: linear-gradient(145deg, #14532d, #166534);
            border-color: #4ade80;
        }
        
        .swot-card.weakness {
            background: linear-gradient(145deg, #fef2f2, #fee2e2);
            border-color: #ef4444;
        }
        .dark .swot-card.weakness {
            background: linear-gradient(145deg, #7f1d1d, #991b1b);
            border-color: #f87171;
        }
        
        .swot-card.opportunity {
            background: linear-gradient(145deg, #eff6ff, #dbeafe);
            border-color: #3b82f6;
        }
        .dark .swot-card.opportunity {
            background: linear-gradient(145deg, #1e3a8a, #1e40af);
            border-color: #60a5fa;
        }
        
        .swot-card.threat {
            background: linear-gradient(145deg, #fffbeb, #fef3c7);
            border-color: #f59e0b;
        }
        .dark .swot-card.threat {
            background: linear-gradient(145deg, #78350f, #92400e);
            border-color: #fbbf24;
        }
        
        .swot-header {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .swot-icon {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 16px;
            font-size: 2rem;
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        
        .dark .swot-icon {
            background: rgba(0, 0, 0, 0.3);
        }
        
        .strength .swot-icon {
            color: #16a34a;
        }
        .weakness .swot-icon {
            color: #dc2626;
        }
        .opportunity .swot-icon {
            color: #2563eb;
        }
        .threat .swot-icon {
            color: #d97706;
        }
        
        .swot-title {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            line-height: 1.2;
        }
        
        .strength .swot-title {
            color: #15803d;
        }
        .dark .strength .swot-title {
            color: #86efac;
        }
        
        .weakness .swot-title {
            color: #b91c1c;
        }
        .dark .weakness .swot-title {
            color: #fca5a5;
        }
        
        .opportunity .swot-title {
            color: #1d4ed8;
        }
        .dark .opportunity .swot-title {
            color: #93c5fd;
        }
        
        .threat .swot-title {
            color: #b45309;
        }
        .dark .threat .swot-title {
            color: #fcd34d;
        }
        
        .swot-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 20px 0;
        }
        
        .swot-stat {
            background: rgba(255, 255, 255, 0.5);
            border-radius: 12px;
            padding: 12px;
            text-align: center;
            backdrop-filter: blur(4px);
        }
        
        .dark .swot-stat {
            background: rgba(0, 0, 0, 0.2);
        }
        
        .swot-stat-value {
            font-size: 1.5rem;
            font-weight: 700;
        }
        .swot-stat-label {
            font-size: 0.75rem;
            font-weight: 500;
            opacity: 0.8;
        }
        
        .swot-features {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin: 20px 0;
        }
        
        .swot-feature {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
            padding: 8px 12px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 10px;
            backdrop-filter: blur(4px);
        }
        
        .dark .swot-feature {
            background: rgba(0, 0, 0, 0.2);
        }
        
        .swot-feature i {
            font-size: 1.2rem;
        }
        
        .swot-footer {
            margin-top: 20px;
            padding-top: 16px;
            border-top: 2px solid rgba(0, 0, 0, 0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .dark .swot-footer {
            border-top-color: rgba(255, 255, 255, 0.1);
        }
        
        .swot-action {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-weight: 600;
            font-size: 0.9rem;
            padding: 8px 16px;
            border-radius: 30px;
            background: white;
            color: #1f2937;
            transition: all 0.3s ease;
        }
        
        .dark .swot-action {
            background: #374151;
            color: white;
        }
        
        .swot-action:hover {
            transform: translateX(5px);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        /* Modal styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: white;
            border-radius: 1rem;
            padding: 2rem;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            transform: translateY(20px);
            transition: transform 0.3s ease;
        }

        .dark .modal-content {
            background-color: #1f2937;
            color: #f3f4f6;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0);
        }

        .modal-body {
            margin-top: 1rem;
            line-height: 1.6;
        }

        .modal-footer {
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        .dark .modal-footer {
            border-top-color: #374151;
        }

        /* Responsive text adjustments */
        @media (max-width: 640px) {
            .hero-title {
                font-size: 2rem !important;
                line-height: 1.2 !important;
            }
            .virtual-card {
                padding: 1rem !important;
            }
            .swot-container {
                gap: 16px;
            }
            .swot-card {
                padding: 20px;
            }
            .swot-title {
                font-size: 1.5rem;
            }
            .swot-icon {
                width: 50px;
                height: 50px;
                font-size: 1.6rem;
            }
        }

        /* Ensure buttons are clickable */
        button {
            cursor: pointer;
        }
    </style>
</head>
  <%- include('../header.ejs') %>
<body class="bg-gradient-to-br from-violet-50 to-cyan-50 dark:from-gray-900 dark:to-violet-900/10 text-gray-900 dark:text-gray-100 min-h-screen">
  

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
        <!-- Page Header -->
        <div class="text-center mb-12 animate-slide-in-left">
            <div class="inline-flex items-center px-5 py-2 bg-gradient-to-r from-violet-600 to-cyan-600 text-white rounded-full text-sm font-bold mb-6 shadow-lg">
                <i class="ri-cloud-fill mr-2"></i>
                Digital Bid Management
            </div>
            <h1 class="hero-title text-4xl md:text-6xl font-bold mb-4">
                <span class="gradient-text-virtual">Virtual Bid</span>
                <br>
                <span class="text-gray-800 dark:text-gray-100">Management</span>
            </h1>
            <p class="text-gray-600 dark:text-gray-300 text-lg max-w-3xl mx-auto">
                Streamline Your Construction Bidding Process with Virtual Bid Management
            </p>
        </div>

        <!-- Hero Image -->
        <div class="rounded-3xl overflow-hidden mb-12 shadow-2xl border-4 border-white dark:border-gray-800 relative">
            <div class="digital-pulse"></div>
            <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80" 
                 alt="Virtual Bid Management" 
                 class="w-full h-64 md:h-96 object-cover relative z-10">
        </div>

        <!-- Intro Section -->
        <div class="mb-12">
            <div class="bg-gradient-to-r from-violet-50 to-cyan-50 dark:from-violet-900/20 dark:to-cyan-900/20 rounded-2xl p-8 border border-violet-200 dark:border-violet-800">
                <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-4">
                    <i class="ri-rocket-line text-violet-600 mr-2"></i>
                    Elevate Your Bidding Process
                </h2>
                <p class="text-gray-600 dark:text-gray-300 mb-6 text-lg">
                    Seamless Bidding Process Management for Increased Success Rates
                </p>
                <p class="text-gray-600 dark:text-gray-300 mb-4">
                    Gone are the days of manual data compilation and endless communication loops. 
                    Our Virtual Bid Manager compiles and updates subcontractor and vendor contacts, 
                    meticulously reviews project plans, and manages the entire bidding process.
                </p>
                <button onclick="openModal(1)" class="mt-2 text-violet-600 dark:text-violet-400 font-medium hover:text-violet-800 dark:hover:text-violet-300 inline-flex items-center cursor-pointer">
                    Learn More About VBM <i class="ri-arrow-right-line ml-1"></i>
                </button>
            </div>
        </div>

        <!-- Key Features -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-8 text-center">
                Unleash Your Potential with a Virtual Bid Manager
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="virtual-card p-6 relative">
                    <div class="vbm-badge" style="background: #06b6d4;" onclick="openModal(2)">Communication</div>
                    <div class="feature-icon bg-cyan-100 dark:bg-cyan-900" onclick="openModal(2)">
                        <i class="ri-chat-3-line text-cyan-600 dark:text-cyan-400 text-xl"></i>
                    </div>
                    <h4 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-3">Unmatched Communication</h4>
                    <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">
                        Timely updates and seamless coordination keeping all parties informed and aligned throughout the bidding journey.
                    </p>
                    <button onclick="openModal(2)" class="text-violet-600 dark:text-violet-400 font-medium text-sm hover:text-violet-800 dark:hover:text-violet-300 inline-flex items-center cursor-pointer">
                        Learn More <i class="ri-arrow-right-line ml-1"></i>
                    </button>
                </div>
                
                <div class="virtual-card p-6 relative">
                    <div class="vbm-badge" onclick="openModal(3)">Analysis</div>
                    <div class="feature-icon bg-violet-100 dark:bg-violet-900" onclick="openModal(3)">
                        <i class="ri-line-chart-line text-violet-600 dark:text-violet-400 text-xl"></i>
                    </div>
                    <h4 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-3">Refined Bid Analysis</h4>
                    <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">
                        Leverage historical bid data to refine your bidding strategies with in-depth analysis of past results.
                    </p>
                    <button onclick="openModal(3)" class="text-violet-600 dark:text-violet-400 font-medium text-sm hover:text-violet-800 dark:hover:text-violet-300 inline-flex items-center cursor-pointer">
                        Learn More <i class="ri-arrow-right-line ml-1"></i>
                    </button>
                </div>
                
                <div class="virtual-card p-6 relative">
                    <div class="vbm-badge" style="background: #10b981;" onclick="openModal(4)">SWOT</div>
                    <div class="feature-icon bg-green-100 dark:bg-green-900" onclick="openModal(4)">
                        <i class="ri-bar-chart-2-line text-green-600 dark:text-green-400 text-xl"></i>
                    </div>
                    <h4 class="text-lg font-bold text-gray-800 dark:text-gray-100 mb-3">Insightful SWOT Analysis</h4>
                    <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">
                        Comprehensive strengths, weaknesses, opportunities, and threats analysis to empower your bidding strategies.
                    </p>
                    <button onclick="openModal(4)" class="text-violet-600 dark:text-violet-400 font-medium text-sm hover:text-violet-800 dark:hover:text-violet-300 inline-flex items-center cursor-pointer">
                        Learn More <i class="ri-arrow-right-line ml-1"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- Process Steps -->
        <div class="mb-12">
            <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-100 mb-6">
                <i class="ri-flow-chart text-violet-600 mr-2"></i>
                Our Virtual Bid Management Process
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <div onclick="openModal(5)" class="virtual-card p-5 cursor-pointer">
                    <div class="flex items-center mb-4">
                        <div class="w-10 h-10 bg-violet-100 dark:bg-violet-900 rounded-lg flex items-center justify-center mr-3 text-violet-600 dark:text-violet-400">
                            <i class="ri-group-line"></i>
                        </div>
                        <h4 class="font-bold text-gray-800 dark:text-gray-100">Local Sub-Contractors</h4>
                    </div>
                    <p class="text-gray-600 dark:text-gray-300 text-sm">
                        Compile and update your network of subcontractors and vendors with ease.
                    </p>
                </div>

                <div onclick="openModal(6)" class="virtual-card p-5 cursor-pointer">
                    <div class="flex items-center mb-4">
                        <div class="w-10 h-10 bg-cyan-100 dark:bg-cyan-900 rounded-lg flex items-center justify-center mr-3 text-cyan-600 dark:text-cyan-400">
                            <i class="ri-file-search-line"></i>
                        </div>
                        <h4 class="font-bold text-gray-800 dark:text-gray-100">Strategic Plan Review</h4>
                    </div>
                    <p class="text-gray-600 dark:text-gray-300 text-sm">
                        Meticulous review of project plans to identify projects with highest potential.
                    </p>
                </div>

                <div onclick="openModal(7)" class="virtual-card p-5 cursor-pointer">
                    <div class="flex items-center mb-4">
                        <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center mr-3 text-blue-600 dark:text-blue-400">
                            <i class="ri-list-check-3"></i>
                        </div>
                        <h4 class="font-bold text-gray-800 dark:text-gray-100">Process Management</h4>
                    </div>
                    <p class="text-gray-600 dark:text-gray-300 text-sm">
                        Managing addendums, change orders, and ensuring timely communication.
                    </p>
                </div>

                <div onclick="openModal(8)" class="virtual-card p-5 cursor-pointer">
                    <div class="flex items-center mb-4">
                        <div class="w-10 h-10 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center mr-3 text-green-600 dark:text-green-400">
                            <i class="ri-lightbulb-flash-line"></i>
                        </div>
                        <h4 class="font-bold text-gray-800 dark:text-gray-100">Intelligent Strategies</h4>
                    </div>
                    <p class="text-gray-600 dark:text-gray-300 text-sm">
                        Data-driven strategies that enhance your bids and secure projects with higher margins.
                    </p>
                </div>
            </div>
        </div>

        <!-- SWOT Analysis - NEW MODERN DESIGN -->
        <div class="mb-16">
            <h2 class="text-3xl font-bold text-gray-800 dark:text-gray-100 mb-8 text-center">
                Comprehensive SWOT Analysis
            </h2>
            <div class="swot-container">
                <!-- Strengths Card -->
                <div onclick="openModal(9)" class="swot-card strength">
                    <div class="swot-header">
                        <div class="swot-icon">
                            <i class="ri-checkbox-circle-line"></i>
                        </div>
                        <div class="swot-title">STRENGTHS</div>
                    </div>
                    
                    <div class="swot-stats">
                        <div class="swot-stat">
                            <div class="swot-stat-value">98%</div>
                            <div class="swot-stat-label">Success Rate</div>
                        </div>
                        <div class="swot-stat">
                            <div class="swot-stat-value">10+</div>
                            <div class="swot-stat-label">Years Exp</div>
                        </div>
                    </div>
                    
                    <div class="swot-features">
                        <div class="swot-feature">
                            <i class="ri-check-line" style="color: #16a34a;"></i>
                            <span>Specialized bid management expertise</span>
                        </div>
                        <div class="swot-feature">
                            <i class="ri-check-line" style="color: #16a34a;"></i>
                            <span>Advanced digital platform</span>
                        </div>
                        <div class="swot-feature">
                            <i class="ri-check-line" style="color: #16a34a;"></i>
                            <span>Professional certified team</span>
                        </div>
                    </div>
                    
                    <div class="swot-footer">
                        <span class="text-sm font-medium opacity-75">Click to learn more</span>
                        <div class="swot-action">
                            View Details <i class="ri-arrow-right-line"></i>
                        </div>
                    </div>
                </div>

                <!-- Weaknesses Card -->
                <div onclick="openModal(10)" class="swot-card weakness">
                    <div class="swot-header">
                        <div class="swot-icon">

            function applyTheme(theme) {
                if (theme === 'dark') {
                    document.documentElement.classList.add('dark');
                    updateThemeUI('dark', themeIcon, themeText);
                    console.log('Applied Dark Theme');
                } else {
                    document.documentElement.classList.remove('dark');
                    updateThemeUI('light', themeIcon, themeText);
                    console.log('Applied Light Theme');
                }
            }
            
            // Apply the theme immediately
            applyTheme(currentTheme);
            
            // Update theme UI elements
            function updateThemeUI(theme, themeIcon, themeText) {
                if (themeIcon && themeText) {
                    if (theme === 'dark') {
                        themeIcon.className = 'ri-sun-line mr-2';
                        themeText.textContent = 'Light';
                    } else {
                        themeIcon.className = 'ri-moon-line mr-2';
                        themeText.textContent = 'Dark';
                    }
                }
            }
            
            // Toggle theme function
            window.toggleTheme = function() {
                const isDark = document.documentElement.classList.contains('dark');
                
                if (isDark) {
                    // Switch to Light Mode
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                    updateThemeUI('light', themeIcon, themeText);
                    console.log('Switched to Light Mode');
                } else {
                    // Switch to Dark Mode
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                    updateThemeUI('dark', themeIcon, themeText);
                    console.log('Switched to Dark Mode');
                }
                
                // Force a reflow to ensure transitions work
                document.body.offsetHeight;
            }
            
            // Add event listener for theme toggle
            if (themeToggle) {
                themeToggle.addEventListener('click', toggleTheme);
            }
            
            // Listen for system theme changes
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
                if (!localStorage.getItem('theme')) {
                    const newTheme = e.matches ? 'dark' : 'light';
                    applyTheme(newTheme);
                    console.log('System theme changed to:', newTheme);
                }
            });
            
            console.log('Theme system initialized');
        });

        // Add hover effects to concrete cards
        document.querySelectorAll('.concrete-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateX(8px)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateX(0)';
            });
        });
        
        // Add animation to process steps
        document.querySelectorAll('.process-step').forEach((step, index) => {
            step.style.animationDelay = `${index * 0.2}s`;
            step.classList.add('animate-fade-in');
        });
        
        // Add click effect to CTA buttons
        document.querySelectorAll('button').forEach(button => {
            if (button.textContent.includes('Contact') || button.textContent.includes('Get') || button.textContent.includes('Start')) {
                button.addEventListener('click', function() {
                    this.classList.add('animate-pulse-slow');
                    setTimeout(() => {
                        this.classList.remove('animate-pulse-slow');
                    }, 2000);
                });
            }
        });

        console.log('Concrete Estimating Page Loaded');
        console.log('Script loaded successfully');
    </script>
</body>
</html>
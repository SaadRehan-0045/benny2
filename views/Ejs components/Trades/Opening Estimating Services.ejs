        // Initialize the page when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Page loaded, modal functionality ready');
            
            // Add door opening animation to cards
            document.querySelectorAll('.opening-card').forEach(card => {
                card.style.animation = 'slideOpen 0.5s ease-out';
                
                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-8px)';
                    this.style.boxShadow = '0 20px 50px rgba(2, 132, 199, 0.2)';
                });
                
                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(-6px)';
                    this.style.boxShadow = '0 15px 40px rgba(2, 132, 199, 0.15)';
                });
            });
            
            // Add door swing animation to time icon
            const swingIcon = document.querySelector('.animate-swing');
            if (swingIcon) {
                swingIcon.style.animationPlayState = 'running';
            }
            
            // Add door opening animation effect to page load
            window.addEventListener('load', () => {
                const heroSection = document.querySelector('section:first-of-type');
                if (heroSection) {
                    heroSection.style.animation = 'slideOpen 1s ease-out';
                }
            });
        });

        // Open modal function - defined globally
        window.openModal = function(modalKey) {
            console.log('Opening modal for:', modalKey);
            const modalOverlay = document.getElementById('modalOverlay');
            const modalTitle = document.getElementById('modalTitle');
            const modalBody = document.getElementById('modalBody');
            
            // Check if data exists
            if (openingData[modalKey]) {
                modalTitle.textContent = openingData[modalKey].title;
                modalBody.innerHTML = openingData[modalKey].content;
            } else {
                console.warn('Data not found for key:', modalKey, 'using fallback');
                modalTitle.textContent = 'Opening Estimating Services';
                modalBody.innerHTML = `
                    <p class="text-xs sm:text-sm">Detailed information about this opening estimating service is available. Contact BENNY ESTIMATES for more information.</p>
                    ${bennyInfo}
                `;
            }
            
            // Show modal
            modalOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // Close modal function
        window.closeModal = function() {
            const modalOverlay = document.getElementById('modalOverlay');
            modalOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close modal on outside click
        window.closeModalOnOutsideClick = function(event) {
            if (event.target === document.getElementById('modalOverlay')) {
                closeModal();
            }
        }

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                const modalOverlay = document.getElementById('modalOverlay');
                if (modalOverlay.classList.contains('active')) {
                    closeModal();
                }
            }
        });

        // Make sure all clickable elements work even if they have nested elements
        document.querySelectorAll('[onclick]').forEach(element => {
            element.addEventListener('click', function(e) {
                // Prevent event from bubbling up if clicked on a child
                if (e.target !== this && e.target.closest('[onclick]') !== this) {
                    return;
                }
                // The onclick attribute will handle the rest
            });
        });
        
        console.log('Opening Estimating page loaded with orange theme and modal functionality');
    </script>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Opening Estimating Services | BENNY ESTIMATES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        },
                        opening: {
                            50: '#f0f9ff',
                            100: '#e0f2fe',
                            200: '#bae6fd',
                            300: '#7dd3fc',
                            400: '#38bdf8',
                            500: '#0ea5e9',
                            600: '#0284c7',
                            700: '#0369a1',
                            800: '#075985',
                            900: '#0c4a6e',
                        },
                        orange: {
                            50: '#fff7ed',
                            100: '#ffedd5',
                            200: '#fed7aa',
                            300: '#fdba74',
                            400: '#fb923c',
                            500: '#f97316',
                            600: '#ea580c',
                            700: '#c2410c',
                            800: '#9a3412',
                            900: '#7c2d12',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-in-out',
                        'slide-open': 'slideOpen 1s ease-in-out',
                        'swing': 'swing 3s ease-in-out infinite',
                        'modal-enter': 'modalEnter 0.3s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideOpen: {
                            '0%': { transform: 'translateX(-100%)' },
                            '100%': { transform: 'translateX(0)' },
                        },
                        swing: {
                            '0%, 100%': { transform: 'rotate(0deg)' },
                            '25%': { transform: 'rotate(2deg)' },
                            '75%': { transform: 'rotate(-2deg)' },
                        },
                        modalEnter: {
                            '0%': { opacity: '0', transform: 'scale(0.95) translateY(-10px)' },
                            '100%': { opacity: '1', transform: 'scale(1) translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        /* Opening theme styling */
        .opening-gradient {
            background: linear-gradient(135deg, #0284c7 0%, #075985 100%);
        }
        
        .dark .opening-gradient {
            background: linear-gradient(135deg, #38bdf8 0%, #0284c7 100%);
        }
        
        /* Door frame pattern */
        .frame-pattern {
            background-image: 
                linear-gradient(90deg, transparent 95%, rgba(2, 132, 199, 0.1) 95%),
                linear-gradient(transparent 95%, rgba(2, 132, 199, 0.1) 95%);
            background-size: 50px 50px;
        }
        
        .dark .frame-pattern {
            background-image: 
                linear-gradient(90deg, transparent 95%, rgba(56, 189, 248, 0.1) 95%),
                linear-gradient(transparent 95%, rgba(56, 189, 248, 0.1) 95%);
            background-size: 50px 50px;
        }
        
        /* Opening card effect */
        .opening-card {
            border: 2px solid #bae6fd;
            border-top: 5px solid #0284c7;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        
        .opening-card:before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, #38bdf8, transparent);
            animation: slideOpen 2s linear infinite;
        }
        
        .opening-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 40px rgba(2, 132, 199, 0.15);
            border-color: #7dd3fc;
        }
        
        .dark .opening-card {
            border-color: #075985;
        }
        
        .dark .opening-card:hover {
            box-shadow: 0 15px 40px rgba(56, 189, 248, 0.2);
            border-color: #38bdf8;
        }
        
        /* Window pane effect */
        .window-pane {
            background-image: 
                linear-gradient(90deg, transparent 49%, rgba(2, 132, 199, 0.1) 49%, rgba(2, 132, 199, 0.1) 51%, transparent 51%),
                linear-gradient(transparent 49%, rgba(2, 132, 199, 0.1) 49%, rgba(2, 132, 199, 0.1) 51%, transparent 51%);
            background-size: 40px 40px;
        }
        
        .dark .window-pane {
            background-image: 
                linear-gradient(90deg, transparent 49%, rgba(56, 189, 248, 0.1) 49%, rgba(56, 189, 248, 0.1) 51%, transparent 51%),
                linear-gradient(transparent 49%, rgba(56, 189, 248, 0.1) 49%, rgba(56, 189, 248, 0.1) 51%, transparent 51%);
            background-size: 40px 40px;
        }
        
        /* Door handle effect */
        .handle-effect {
            position: relative;
        }
        
        .handle-effect:after {
            content: '';
            position: absolute;
            top: 50%;
            right: 10px;
            width: 6px;
            height: 12px;
            background: #f59e0b;
            border-radius: 3px;
            transform: translateY(-50%);
        }

        /* Modal styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: white;
            border-radius: 1rem;
            padding: 1.5rem;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            transform: translateY(20px) scale(0.95);
            transition: all 0.3s ease;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            margin: 1rem;
        }

        .dark .modal-content {
            background-color: #1f2937;
            color: #f3f4f6;
            border: 1px solid #374151;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0) scale(1);
        }

        .modal-body {
            margin-top: 1rem;
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .modal-body p {
            margin-bottom: 1rem;
        }

        .modal-body ul {
            margin: 1rem 0;
            padding-left: 1.5rem;
        }

        .modal-body li {
            margin-bottom: 0.5rem;
        }

        .modal-footer {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        .dark .modal-footer {
            border-top-color: #374151;
        }

        /* Custom scrollbar for modal */
        .modal-content::-webkit-scrollbar {
            width: 6px;
        }

        .modal-content::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .modal-content::-webkit-scrollbar-thumb {
            background: #f97316;
            border-radius: 10px;
        }

        .dark .modal-content::-webkit-scrollbar-track {
            background: #374151;
        }

        .dark .modal-content::-webkit-scrollbar-thumb {
            background: #fb923c;
        }

        /* Ensure buttons are clickable */
        button, .cursor-pointer, [onclick] {
            cursor: pointer;
        }

        /* Button color override - Orange theme for all CTAs */
        .btn-estimate {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
            border: none !important;
            transition: all 0.3s ease;
        }
        
        .btn-estimate:hover {
            background: linear-gradient(135deg, #ea580c, #c2410c) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.4) !important;
        }
        
        .dark .btn-estimate {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }
        
        .dark .btn-estimate:hover {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
        }
        
        .btn-estimate i {
            color: white !important;
        }

        /* Orange gradient for featured cards */
        .orange-gradient-card {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
        }
        
        .dark .orange-gradient-card {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }

        /* Orange text for highlights */
        .text-orange-highlight {
            color: #f97316 !important;
        }
        
        .dark .text-orange-highlight {
            color: #fb923c !important;
        }

        /* Orange border for cards */
        .border-orange-highlight {
            border-color: #f97316 !important;
        }
        
        .dark .border-orange-highlight {
            border-color: #fb923c !important;
        }

        /* Orange background for icons */
        .bg-orange-light {
            background-color: #fff7ed !important;
        }
        
        .dark .bg-orange-light {
            background-color: #7c2d12 !important;
        }

        /* Responsive typography */
        @media (max-width: 640px) {
            .hero-title {
                font-size: 1.75rem !important;
                line-height: 1.2 !important;
            }
            
            .section-title {
                font-size: 1.5rem !important;
            }
            
            .card-title {
                font-size: 1.1rem !important;
            }
        }

        /* Header spacing fix */
        .main-content {
            padding-top: 5rem;
        }

        @media (min-width: 1024px) {
            .main-content {
                padding-top: 6rem;
            }
        }
    </style>
</head>

                        <a href="tel:+12898017224" class="px-2 sm:px-2.5 lg:px-3 py-1 sm:py-1.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-xs sm:text-xs lg:text-sm">

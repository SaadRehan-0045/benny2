    <script>
        // BENNY ESTIMATES contact information template
        const bennyInfo = `
            <div class="bg-lumber-50 dark:bg-gray-700 p-2 sm:p-3 lg:p-4 rounded-lg mt-2 sm:mt-3 border-l-4 border-lumber-500">
                <p class="font-semibold text-lumber-700 dark:text-lumber-400 flex items-center text-xs sm:text-sm">
                    <i class="ri-tools-fill mr-1 sm:mr-2"></i>
                    BENNY ESTIMATES
                </p>
                <p class="mt-1 sm:mt-2 text-xs"><i class="ri-map-pin-line mr-1 sm:mr-2 text-lumber-600"></i>96 Jones Street, New York, USA</p>
                <p class="text-xs"><i class="ri-mail-line mr-1 sm:mr-2 text-lumber-600"></i><a href="mailto:Ben@bennyestimates.com" class="hover:underline">Ben@bennyestimates.com</a></p>
                <p class="text-xs"><i class="ri-phone-line mr-1 sm:mr-2 text-lumber-600"></i><a href="tel:+12898017224" class="hover:underline">+1 (289) 801-7224</a></p>
                <p class="text-xs mt-1 sm:mt-2 text-gray-600 dark:text-gray-400"><i class="ri-time-line mr-1"></i>Call us any time</p>
            </div>
        `;

        // Modal content data structure (keep all your existing modal content here)
        const lumberData = {
            estimate: {
                title: 'Get Your Lumber Takeoff Estimate',
                content: `
                    <div class="space-y-2 sm:space-y-3">
                        <p class="text-sm sm:text-base font-semibold text-lumber-600 dark:text-lumber-400">Ready to Get Started?</p>
                        <p class="text-xs sm:text-sm">Contact BENNY ESTIMATES today for a free consultation and quote for your lumber takeoff needs. Our team of experts is ready to help you with accurate, detailed estimates for your projects.</p>
                        
                        <p class="font-semibold mt-2 sm:mt-3 text-xs sm:text-sm">What We Need From You:</p>
                        <ul class="list-disc pl-3 sm:pl-4 space-y-1 text-xs sm:text-sm">
                            <li>Project plans and specifications (PDF, CAD, or digital formats)</li>
                            <li>Scope of work details</li>
                            <li>Lumber grade preferences if any</li>
                            <li>Project timeline and delivery requirements</li>
                        </ul>
                        
                        ${bennyInfo}
                    </div>
                `
            },
            // Add all other modal content as per your original code
            // For brevity, I'm showing just one, but keep all your existing modal content
        };

        // Open modal function
        window.openModal = function(modalKey) {
            console.log('Opening modal for:', modalKey);
            const modalOverlay = document.getElementById('modalOverlay');
            const modalTitle = document.getElementById('modalTitle');
            const modalBody = document.getElementById('modalBody');
            
            // Check if data exists, otherwise use fallback
            if (!lumberData[modalKey]) {
                modalTitle.textContent = 'Lumber Takeoff Services';
                modalBody.innerHTML = `
                    <p class="text-xs sm:text-sm">Detailed information about this lumber takeoff service is available. Contact BENNY ESTIMATES for more information.</p>
                    ${bennyInfo}
                `;
                modalOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
                return;
            }
            
            const data = lumberData[modalKey];
            modalTitle.textContent = data.title;
            modalBody.innerHTML = data.content;
            modalOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // Close modal function
        window.closeModal = function() {
            const modalOverlay = document.getElementById('modalOverlay');
            modalOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close modal on outside click
        window.closeModalOnOutsideClick = function(event) {
            if (event.target === document.getElementById('modalOverlay')) {
                closeModal();
            }
        }

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeModal();
            }
        });
        
        console.log('Lumber Takeoff page loaded with updated styling');
    </script>

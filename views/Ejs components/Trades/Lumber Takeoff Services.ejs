<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumber Takeoff Services | BENNY ESTIMATES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        },
                        lumber: {
                            50: '#fefce8',
                            100: '#fef9c3',
                            200: '#fef08a',
                            300: '#fde047',
                            400: '#facc15',
                            500: '#eab308',
                            600: '#ca8a04',
                            700: '#a16207',
                            800: '#854d0e',
                            900: '#713f12',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-in-out',
                        'saw': 'saw 2s ease-in-out infinite',
                        'wood-grain': 'woodGrain 10s linear infinite',
                        'modal-enter': 'modalEnter 0.3s ease-out',
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                        'bounce-slow': 'bounce 2s infinite',
                        'shine': 'shine 3s ease-in-out infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        saw: {
                            '0%, 100%': { transform: 'rotate(0deg)' },
                            '25%': { transform: 'rotate(5deg)' },
                            '75%': { transform: 'rotate(-5deg)' },
                        },
                        woodGrain: {
                            '0%': { backgroundPosition: '0% 0%' },
                            '100%': { backgroundPosition: '100% 100%' },
                        },
                        modalEnter: {
                            '0%': { opacity: '0', transform: 'scale(0.95) translateY(-10px)' },
                            '100%': { opacity: '1', transform: 'scale(1) translateY(0)' },
                        },
                        shine: {
                            '0%': { left: '-100%' },
                            '20%, 100%': { left: '100%' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        /* Lumber theme styling */
        .lumber-gradient {
            background: linear-gradient(135deg, #ca8a04 0%, #a16207 100%);
        }
        
        .dark .lumber-gradient {
            background: linear-gradient(135deg, #eab308 0%, #ca8a04 100%);
        }
        
        /* Wood grain background */
        .wood-bg {
            background-image: 
                linear-gradient(90deg, 
                    rgba(202, 138, 4, 0.05) 0%, 
                    rgba(202, 138, 4, 0.1) 50%, 
                    rgba(202, 138, 4, 0.05) 100%);
            background-size: 200% 200%;
        }
        
        .dark .wood-bg {
            background-image: 
                linear-gradient(90deg, 
                    rgba(234, 179, 8, 0.05) 0%, 
                    rgba(234, 179, 8, 0.1) 50%, 
                    rgba(234, 179, 8, 0.05) 100%);
            background-size: 200% 200%;
        }
        
        /* Lumber card hover effect */
        .lumber-card {
            border: 1px solid #fde047;
            border-left: 4px solid #ca8a04;
            transition: all 0.3s ease;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        
        .lumber-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(202, 138, 4, 0.15);
        }
        
        .dark .lumber-card {
            border-color: #854d0e;
        }
        
        .dark .lumber-card:hover {
            box-shadow: 0 15px 40px rgba(202, 138, 4, 0.25);
        }
        
        /* Saw blade pattern */
        .saw-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ca8a04' fill-opacity='0.05' fill-rule='evenodd'%3E%3Cpath d='M0 40L40 0H20L0 20M40 40V20L20 40'/%3E%3C/g%3E%3C/svg%3E");
        }
        
        .dark .saw-pattern {
            background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23eab308' fill-opacity='0.05' fill-rule='evenodd'%3E%3Cpath d='M0 40L40 0H20L0 20M40 40V20L20 40'/%3E%3C/g%3E%3C/svg%3E");
        }
        
        /* Board texture */
        .board-texture {
            background: repeating-linear-gradient(
                90deg,
                transparent,
                transparent 2px,
                rgba(202, 138, 4, 0.05) 2px,
                rgba(202, 138, 4, 0.05) 4px
            );
        }
        
        .dark .board-texture {
            background: repeating-linear-gradient(
                90deg,
                transparent,
                transparent 2px,
                rgba(234, 179, 8, 0.05) 2px,
                rgba(234, 179, 8, 0.05) 4px
            );
        }

        /* Modal styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: white;
            border-radius: 1rem;
            padding: 1.5rem;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            transform: translateY(20px) scale(0.95);
            transition: all 0.3s ease;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            margin: 1rem;
        }

        .dark .modal-content {
            background-color: #1f2937;
            color: #f3f4f6;
            border: 1px solid #374151;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0) scale(1);
        }

        .modal-body {
            margin-top: 1rem;
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .modal-body p {
            margin-bottom: 1rem;
        }

        .modal-body ul {
            margin: 1rem 0;
            padding-left: 1.5rem;
        }

        .modal-body li {
            margin-bottom: 0.5rem;
        }

        .modal-footer {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        .dark .modal-footer {
            border-top-color: #374151;
        }

        /* Custom scrollbar for modal */
        .modal-content::-webkit-scrollbar {
            width: 6px;
        }

        .modal-content::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .modal-content::-webkit-scrollbar-thumb {
            background: #ca8a04;
            border-radius: 10px;
        }

        .dark .modal-content::-webkit-scrollbar-track {
            background: #374151;
        }

        .dark .modal-content::-webkit-scrollbar-thumb {
            background: #eab308;
        }

        /* Ensure buttons are clickable */
        button, .cursor-pointer {
            cursor: pointer;
        }

        /* Button shine effect */
        .btn-shine {
            position: relative;
            overflow: hidden;
        }

        .btn-shine::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            animation: shine 3s ease-in-out infinite;
        }

        /* Header spacing fix */
        .main-content {
            padding-top: 5rem;
        }

        @media (min-width: 1024px) {
            .main-content {
                padding-top: 6rem;
            }
        }

        /* Button color override - Orange theme for main button */
        .btn-estimate {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
            border: none !important;
            transition: all 0.3s ease;
        }
        
        .btn-estimate:hover {
            background: linear-gradient(135deg, #ea580c, #c2410c) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.4) !important;
        }
        
        .dark .btn-estimate {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }
        
        .dark .btn-estimate:hover {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
        }
        
        .btn-estimate i {
            color: white !important;
        }

        /* Orange theme for Start Project button */
        .btn-start-project {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
            border: none !important;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px -1px rgba(249, 115, 22, 0.3) !important;
        }
        
        .btn-start-project:hover {
            background: linear-gradient(135deg, #ea580c, #c2410c) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(249, 115, 22, 0.4) !important;
        }
        
        .dark .btn-start-project {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }
        
        .dark .btn-start-project:hover {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
        }
    </style>
</head>

        // Initialize the page when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Page loaded, modal functionality ready');
            
            // Add circuit animation to process steps
            let circuitDelay = 0;
            document.querySelectorAll('.animate-pulse-circuit').forEach(element => {
                element.style.animationDelay = `${circuitDelay}s`;
                circuitDelay += 0.2;
            });
            
            // Add spark animation to electrical elements
            document.querySelectorAll('.spark').forEach(element => {
                element.style.animation = 'sparkFlash 1s ease-in-out infinite';
            });
        });

        // Open modal function - defined globally
        window.openModal = function(modalKey) {
            console.log('Opening modal for:', modalKey);
            const modalOverlay = document.getElementById('modalOverlay');
            const modalTitle = document.getElementById('modalTitle');
            const modalBody = document.getElementById('modalBody');
            
            // Check if data exists
            if (mepData[modalKey]) {
                modalTitle.textContent = mepData[modalKey].title;
                modalBody.innerHTML = mepData[modalKey].content;
            } else {
                console.warn('Data not found for key:', modalKey, 'using fallback');
                modalTitle.textContent = 'MEP Estimating Services';
                modalBody.innerHTML = `
                    <p class="text-xs sm:text-sm">Detailed information about this MEP estimating service is available. Contact BENNY ESTIMATES for more information.</p>
                    ${bennyInfo}
                `;
            }
            
            // Show modal
            modalOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // Close modal function
        window.closeModal = function() {
            const modalOverlay = document.getElementById('modalOverlay');
            modalOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close modal on outside click
        window.closeModalOnOutsideClick = function(event) {
            if (event.target === document.getElementById('modalOverlay')) {
                closeModal();
            }
        }

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                const modalOverlay = document.getElementById('modalOverlay');
                if (modalOverlay.classList.contains('active')) {
                    closeModal();
                }
            }
        });

        // Make sure all clickable elements work even if they have nested elements
        document.querySelectorAll('[onclick]').forEach(element => {
            element.addEventListener('click', function(e) {
                // Prevent event from bubbling up if clicked on a child
                if (e.target !== this && e.target.closest('[onclick]') !== this) {
                    return;
                }
                // The onclick attribute will handle the rest
            });
        });
        
        console.log('MEP Estimating page loaded with fixed modal functionality');
    </script>

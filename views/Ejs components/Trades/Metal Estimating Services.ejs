<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Metal Estimating Services | BENNY ESTIMATES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        },
                        metal: {
                            50: '#fafafa',
                            100: '#f5f5f5',
                            200: '#e5e5e5',
                            300: '#d4d4d4',
                            400: '#a3a3a3',
                            500: '#737373',
                            600: '#525252',
                            700: '#404040',
                            800: '#262626',
                            900: '#171717',
                        },
                        orange: {
                            50: '#fff7ed',
                            100: '#ffedd5',
                            200: '#fed7aa',
                            300: '#fdba74',
                            400: '#fb923c',
                            500: '#f97316',
                            600: '#ea580c',
                            700: '#c2410c',
                            800: '#9a3412',
                            900: '#7c2d12',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-in-out',
                        'metal-shine': 'metalShine 2s ease-in-out infinite',
                        'spark': 'spark 1s ease-in-out infinite',
                        'modal-enter': 'modalEnter 0.3s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        metalShine: {
                            '0%, 100%': { opacity: '1' },
                            '50%': { opacity: '0.8' },
                        },
                        spark: {
                            '0%, 100%': { opacity: '0' },
                            '50%': { opacity: '1' },
                        },
                        modalEnter: {
                            '0%': { opacity: '0', transform: 'scale(0.95) translateY(-10px)' },
                            '100%': { opacity: '1', transform: 'scale(1) translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        /* Metal theme styling */
        .metal-gradient {
            background: linear-gradient(135deg, #525252 0%, #404040 100%);
        }
        
        .dark .metal-gradient {
            background: linear-gradient(135deg, #737373 0%, #525252 100%);
        }
        
        /* Steel grid pattern */
        .steel-pattern {
            background-image: 
                linear-gradient(90deg, rgba(82, 82, 82, 0.1) 1px, transparent 1px),
                linear-gradient(rgba(82, 82, 82, 0.1) 1px, transparent 1px);
            background-size: 30px 30px;
        }
        
        .dark .steel-pattern {
            background-image: 
                linear-gradient(90deg, rgba(115, 115, 115, 0.1) 1px, transparent 1px),
                linear-gradient(rgba(115, 115, 115, 0.1) 1px, transparent 1px);
            background-size: 30px 30px;
        }
        
        /* Metal card effect */
        .metal-card {
            border: 1px solid #d4d4d4;
            border-left: 6px solid #525252;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        
        .metal-card:before {
            content: '';
            position: absolute;
            top: -100%;
            left: -100%;
            width: 300%;
            height: 300%;
            background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%);
            transition: transform 0.6s ease;
            transform: translate(100%, 100%);
        }
        
        .metal-card:hover:before {
            transform: translate(-100%, -100%);
        }
        
        .metal-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 40px rgba(82, 82, 82, 0.15);
            border-color: #a3a3a3;
        }
        
        .dark .metal-card {
            border-color: #404040;
        }
        
        .dark .metal-card:hover {
            box-shadow: 0 15px 40px rgba(115, 115, 115, 0.2);
            border-color: #737373;
        }
        
        /* Welding spark effect */
        .weld-spark {
            position: relative;
        }
        
        .weld-spark:after {
            content: '';
            position: absolute;
            top: 0;
            right: -8px;
            width: 4px;
            height: 4px;
            background: #f59e0b;
            border-radius: 50%;
            box-shadow: 0 0 10px #f59e0b;
        }
        
        /* Bolt pattern */
        .bolt-pattern {
            background-image: 
                radial-gradient(circle at 25% 25%, rgba(115, 115, 115, 0.1) 2px, transparent 2px),
                radial-gradient(circle at 75% 75%, rgba(115, 115, 115, 0.1) 2px, transparent 2px);
            background-size: 40px 40px;
        }

        /* Modal styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: white;
            border-radius: 1rem;
            padding: 1.5rem;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            transform: translateY(20px) scale(0.95);
            transition: all 0.3s ease;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            margin: 1rem;
        }

        .dark .modal-content {
            background-color: #1f2937;
            color: #f3f4f6;
            border: 1px solid #374151;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0) scale(1);
        }

        .modal-body {
            margin-top: 1rem;
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .modal-body p {
            margin-bottom: 1rem;
        }

        .modal-body ul {
            margin: 1rem 0;
            padding-left: 1.5rem;
        }

        .modal-body li {
            margin-bottom: 0.5rem;
        }

        .modal-footer {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        .dark .modal-footer {
            border-top-color: #374151;
        }

        /* Custom scrollbar for modal */
        .modal-content::-webkit-scrollbar {
            width: 6px;
        }

        .modal-content::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .modal-content::-webkit-scrollbar-thumb {
            background: #f97316;
            border-radius: 10px;
        }

        .dark .modal-content::-webkit-scrollbar-track {
            background: #374151;
        }

        .dark .modal-content::-webkit-scrollbar-thumb {
            background: #fb923c;
        }

        /* Ensure buttons are clickable */
        button, .cursor-pointer, [onclick] {
            cursor: pointer;
        }

        /* Button color override - Orange theme for all CTAs */
        .btn-estimate {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
            border: none !important;
            transition: all 0.3s ease;
        }
        
        .btn-estimate:hover {
            background: linear-gradient(135deg, #ea580c, #c2410c) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.4) !important;
        }
        
        .dark .btn-estimate {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }
        
        .dark .btn-estimate:hover {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
        }
        
        .btn-estimate i {
            color: white !important;
        }

        /* Orange theme for secondary buttons */
        .btn-secondary {
            background: transparent !important;
            color: white !important;
            border: 2px solid white !important;
            transition: all 0.3s ease;
        }
        
        .btn-secondary:hover {
            background: rgba(255,255,255,0.1) !important;
            transform: translateY(-2px);
        }
        
        .dark .btn-secondary {
            border-color: #fb923c !important;
            color: #fb923c !important;
        }
        
        .dark .btn-secondary:hover {
            background: rgba(249, 115, 22, 0.1) !important;
        }

        /* Orange gradient for featured cards */
        .orange-gradient-card {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
        }
        
        .dark .orange-gradient-card {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }

        /* Orange text for highlights */
        .text-orange-highlight {
            color: #f97316 !important;
        }
        
        .dark .text-orange-highlight {
            color: #fb923c !important;
        }

        /* Orange border for cards */
        .border-orange-highlight {
            border-color: #f97316 !important;
        }
        
        .dark .border-orange-highlight {
            border-color: #fb923c !important;
        }

        /* Orange background for icons */
        .bg-orange-light {
            background-color: #fff7ed !important;
        }
        
        .dark .bg-orange-light {
            background-color: #7c2d12 !important;
        }

        /* Responsive typography */
        @media (max-width: 640px) {
            .hero-title {
                font-size: 1.75rem !important;
                line-height: 1.2 !important;
            }
            
            .section-title {
                font-size: 1.5rem !important;
            }
            
            .card-title {
                font-size: 1.1rem !important;
            }
        }

        /* Header spacing fix */
        .main-content {
            padding-top: 5rem;
        }

        @media (min-width: 1024px) {
            .main-content {
                padding-top: 6rem;
            }
        }
    </style>
</head>

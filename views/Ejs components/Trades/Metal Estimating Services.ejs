        // Initialize the page when DOM is loaded
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Page loaded, modal functionality ready');
            
            // Add metal shine animation
            document.querySelectorAll('.animate-metal-shine').forEach(element => {
                element.style.animationPlayState = 'running';
            });
            
            // Add welding spark animation
            document.querySelectorAll('.weld-spark').forEach(element => {
                element.style.animation = 'spark 1s ease-in-out infinite';
            });
            
            // Add shimmer effect to metal cards on page load
            setTimeout(() => {
                document.querySelectorAll('.metal-card').forEach((card, index) => {
                    setTimeout(() => {
                        card.style.transition = 'box-shadow 0.3s ease';
                        card.style.boxShadow = '0 0 20px rgba(82, 82, 82, 0.3)';
                        setTimeout(() => {
                            card.style.boxShadow = '';
                        }, 300);
                    }, index * 100);
                });
            }, 500);
        });

        // Open modal function - defined globally
        window.openModal = function(modalKey) {
            console.log('Opening modal for:', modalKey);
            const modalOverlay = document.getElementById('modalOverlay');
            const modalTitle = document.getElementById('modalTitle');
            const modalBody = document.getElementById('modalBody');
            
            // Check if data exists
            if (metalData[modalKey]) {
                modalTitle.textContent = metalData[modalKey].title;
                modalBody.innerHTML = metalData[modalKey].content;
            } else {
                console.warn('Data not found for key:', modalKey, 'using fallback');
                modalTitle.textContent = 'Metal Estimating Services';
                modalBody.innerHTML = `
                    <p class="text-xs sm:text-sm">Detailed information about this metal estimating service is available. Contact BENNY ESTIMATES for more information.</p>
                    ${bennyInfo}
                `;
            }
            
            // Show modal
            modalOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        // Close modal function
        window.closeModal = function() {
            const modalOverlay = document.getElementById('modalOverlay');
            modalOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close modal on outside click
        window.closeModalOnOutsideClick = function(event) {
            if (event.target === document.getElementById('modalOverlay')) {
                closeModal();
            }
        }

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                const modalOverlay = document.getElementById('modalOverlay');
                if (modalOverlay.classList.contains('active')) {
                    closeModal();
                }
            }
        });

        // Make sure all clickable elements work even if they have nested elements
        document.querySelectorAll('[onclick]').forEach(element => {
            element.addEventListener('click', function(e) {
                // Prevent event from bubbling up if clicked on a child
                if (e.target !== this && e.target.closest('[onclick]') !== this) {
                    return;
                }
                // The onclick attribute will handle the rest
            });
        });
        
        console.log('Metal Estimating page loaded with orange theme and modal functionality');
    </script>

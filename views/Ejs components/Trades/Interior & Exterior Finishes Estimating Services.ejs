        // Open modal function - matches page#2 pattern
        window.openModal = function(modalKey) {
            console.log('Opening modal for:', modalKey);
            const modalOverlay = document.getElementById('modalOverlay');
            const modalTitle = document.getElementById('modalTitle');
            const modalBody = document.getElementById('modalBody');
            
            const data = finishesData[modalKey];
            if (data) {
                modalTitle.textContent = data.title;
                modalBody.innerHTML = data.content;
                modalOverlay.classList.add('active');
                document.body.style.overflow = 'hidden'; // Prevent scrolling
            } else {
                console.error('Data not found for key:', modalKey);
                // Fallback content
                modalTitle.textContent = 'Finishes Estimating';
                modalBody.innerHTML = `
                    <p>Detailed information about this finishes estimating service is available. Contact BENNY ESTIMATES for more information.</p>
                    ${bennyInfo}
                `;
                modalOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }
        }

        // Close modal function
        window.closeModal = function() {
            const modalOverlay = document.getElementById('modalOverlay');
            modalOverlay.classList.remove('active');
            document.body.style.overflow = ''; // Restore scrolling
        }

        // Close modal on outside click
        window.closeModalOnOutsideClick = function(event) {
            if (event.target === document.getElementById('modalOverlay')) {
                closeModal();
            }
        }

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeModal();
            }
        });

        // Add hover effects to finish cards
        document.querySelectorAll('.finish-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-10px) scale(1.03)';
                this.style.boxShadow = '0 25px 60px rgba(217, 70, 239, 0.2)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(-8px) scale(1.02)';
                this.style.boxShadow = '0 20px 50px rgba(217, 70, 239, 0.15)';
            });
        });
        
        // Add animation to process steps
        let animationDelay = 0;
        document.querySelectorAll('.animate-slide-up').forEach(step => {
            step.style.animationDelay = `${animationDelay}s`;
            animationDelay += 0.2;
        });
        
        // Add texture pattern effect to hero section
        const textureOverlay = document.querySelector('.texture-overlay');
        if (textureOverlay) {
            textureOverlay.style.position = 'relative';
            const pattern = document.createElement('div');
            pattern.style.position = 'absolute';
            pattern.style.top = '0';
            pattern.style.left = '0';
            pattern.style.right = '0';
            pattern.style.bottom = '0';
            pattern.style.backgroundImage = document.documentElement.classList.contains('dark') 

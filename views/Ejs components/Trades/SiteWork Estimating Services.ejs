<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SiteWork Estimating Services | BENNY ESTIMATES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        },
                        sitework: {
                            50: '#faf5ff',
                            100: '#f3e8ff',
                            200: '#e9d5ff',
                            300: '#d8b4fe',
                            400: '#c084fc',
                            500: '#a855f7',
                            600: '#9333ea',
                            700: '#7e22ce',
                            800: '#6b21a8',
                            900: '#581c87',
                        },
                        orange: {
                            50: '#fff7ed',
                            100: '#ffedd5',
                            200: '#fed7aa',
                            300: '#fdba74',
                            400: '#fb923c',
                            500: '#f97316',
                            600: '#ea580c',
                            700: '#c2410c',
                            800: '#9a3412',
                            900: '#7c2d12',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-in-out',
                        'ground-shift': 'groundShift 3s ease-in-out infinite',
                        'rise-up': 'riseUp 1s ease-out',
                        'modal-enter': 'modalEnter 0.3s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        groundShift: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-5px)' },
                        },
                        riseUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        },
                        modalEnter: {
                            '0%': { opacity: '0', transform: 'scale(0.95) translateY(-10px)' },
                            '100%': { opacity: '1', transform: 'scale(1) translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        /* SiteWork theme styling */
        .sitework-gradient {
            background: linear-gradient(135deg, #9333ea 0%, #7e22ce 100%);
        }
        
        .dark .sitework-gradient {
            background: linear-gradient(135deg, #c084fc 0%, #9333ea 100%);
        }
        
        /* Ground pattern */
        .ground-pattern {
            background-image: 
                radial-gradient(circle at 25% 25%, rgba(147, 51, 234, 0.1) 2px, transparent 2px),
                radial-gradient(circle at 75% 75%, rgba(147, 51, 234, 0.1) 2px, transparent 2px);
            background-size: 60px 60px;
        }
        
        .dark .ground-pattern {
            background-image: 
                radial-gradient(circle at 25% 25%, rgba(192, 132, 252, 0.1) 2px, transparent 2px),
                radial-gradient(circle at 75% 75%, rgba(192, 132, 252, 0.1) 2px, transparent 2px);
            background-size: 60px 60px;
        }
        
        /* SiteWork card effect */
        .sitework-card {
            border: 2px solid #e9d5ff;
            border-bottom: 5px solid #9333ea;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        
        .sitework-card:before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 0;
            background: linear-gradient(to top, rgba(147, 51, 234, 0.1), transparent);
            transition: height 0.3s ease;
        }
        
        .sitework-card:hover:before {
            height: 100%;
        }
        
        .sitework-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(147, 51, 234, 0.15);
            border-color: #d8b4fe;
        }
        
        .dark .sitework-card {
            border-color: #6b21a8;
        }
        
        .dark .sitework-card:hover {
            box-shadow: 0 15px 40px rgba(192, 132, 252, 0.2);
            border-color: #c084fc;
        }
        
        /* Excavation pattern */
        .excavation-pattern {
            background-image: 
                linear-gradient(45deg, transparent 65%, rgba(147, 51, 234, 0.05) 65%, rgba(147, 51, 234, 0.05) 75%, transparent 75%),
                linear-gradient(-45deg, transparent 65%, rgba(147, 51, 234, 0.05) 65%, rgba(147, 51, 234, 0.05) 75%, transparent 75%);
            background-size: 30px 30px;
        }
        
        .dark .excavation-pattern {
            background-image: 
                linear-gradient(45deg, transparent 65%, rgba(192, 132, 252, 0.05) 65%, rgba(192, 132, 252, 0.05) 75%, transparent 75%),
                linear-gradient(-45deg, transparent 65%, rgba(192, 132, 252, 0.05) 65%, rgba(192, 132, 252, 0.05) 75%, transparent 75%);
            background-size: 30px 30px;
        }
        
        /* Terrain elevation effect */
        .terrain-effect {
            position: relative;
            cursor: pointer;
        }
        
        .terrain-effect:after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, #9333ea, transparent);
            opacity: 0;
            transition: opacity 0.3s ease;
        }
        
        .terrain-effect:hover:after {
            opacity: 1;
        }

        /* Modal styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: white;
            border-radius: 1rem;
            padding: 1.5rem;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            transform: translateY(20px) scale(0.95);
            transition: all 0.3s ease;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            margin: 1rem;
        }

        .dark .modal-content {
            background-color: #1f2937;
            color: #f3f4f6;
            border: 1px solid #374151;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0) scale(1);
        }

        .modal-body {
            margin-top: 1rem;
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .modal-body p {
            margin-bottom: 1rem;
        }

        .modal-body ul {
            margin: 1rem 0;
            padding-left: 1.5rem;
        }

        .modal-body li {
            margin-bottom: 0.5rem;
        }

        .modal-footer {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        .dark .modal-footer {
            border-top-color: #374151;
        }

        /* Custom scrollbar for modal */
        .modal-content::-webkit-scrollbar {
            width: 6px;
        }

        .modal-content::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .modal-content::-webkit-scrollbar-thumb {
            background: #f97316;
            border-radius: 10px;
        }

        .dark .modal-content::-webkit-scrollbar-track {
            background: #374151;
        }

        .dark .modal-content::-webkit-scrollbar-thumb {
            background: #fb923c;
        }

        /* Ensure buttons are clickable */
        button, .cursor-pointer, [onclick] {
            cursor: pointer;
        }

        /* Button color override - Orange theme for all CTAs */
        .btn-estimate {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
            border: none !important;
            transition: all 0.3s ease;
        }
        
        .btn-estimate:hover {
            background: linear-gradient(135deg, #ea580c, #c2410c) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.4) !important;
        }
        
        .dark .btn-estimate {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }
        
        .dark .btn-estimate:hover {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
        }
        
        .btn-estimate i {
            color: white !important;
        }

        /* Orange theme for secondary buttons */
        .btn-secondary {
            background: transparent !important;
            color: white !important;
            border: 2px solid white !important;
            transition: all 0.3s ease;
        }
        
        .btn-secondary:hover {
            background: rgba(255,255,255,0.1) !important;
            transform: translateY(-2px);
        }
        
        .dark .btn-secondary {
            border-color: #fb923c !important;
            color: #fb923c !important;
        }
        
        .dark .btn-secondary:hover {
            background: rgba(249, 115, 22, 0.1) !important;
        }

        /* Orange gradient for featured cards */
        .orange-gradient-card {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
        }
        
        .dark .orange-gradient-card {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }

        /* Orange text for highlights */
        .text-orange-highlight {
            color: #f97316 !important;
        }
        
        .dark .text-orange-highlight {
            color: #fb923c !important;
        }

        /* Orange border for cards */
        .border-orange-highlight {
            border-color: #f97316 !important;
        }
        
        .dark .border-orange-highlight {
            border-color: #fb923c !important;
        }

        /* Orange background for icons */
        .bg-orange-light {
            background-color: #fff7ed !important;
        }
        
        .dark .bg-orange-light {
            background-color: #7c2d12 !important;
        }

        /* Responsive typography */
        @media (max-width: 640px) {
            .hero-title {
                font-size: 1.75rem !important;
                line-height: 1.2 !important;
            }
            
            .section-title {
                font-size: 1.5rem !important;
            }
            
            .card-title {
                font-size: 1.1rem !important;
            }
        }

        /* Header spacing fix */
        .main-content {
            padding-top: 5rem;
        }

        @media (min-width: 1024px) {
            .main-content {
                padding-top: 6rem;
            }
        }

        /* Remove default margin/padding for body */
        body {
            margin: 0;
            padding: 0;
        }
    </style>
</head>
<%- include('../header.ejs') %>

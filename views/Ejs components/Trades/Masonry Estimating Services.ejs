<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Masonry Estimating Services | BENNY ESTIMATES</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        },
                        masonry: {
                            50: '#f8fafc',
                            100: '#f1f5f9',
                            200: '#e2e8f0',
                            300: '#cbd5e1',
                            400: '#94a3b8',
                            500: '#64748b',
                            600: '#475569',
                            700: '#334155',
                            800: '#1e293b',
                            900: '#0f172a',
                        },
                        orange: {
                            50: '#fff7ed',
                            100: '#ffedd5',
                            200: '#fed7aa',
                            300: '#fdba74',
                            400: '#fb923c',
                            500: '#f97316',
                            600: '#ea580c',
                            700: '#c2410c',
                            800: '#9a3412',
                            900: '#7c2d12',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-in-out',
                        'brick': 'brickBuild 3s ease-in-out infinite',
                        'wall-grow': 'wallGrow 2s ease-out',
                        'modal-enter': 'modalEnter 0.3s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        brickBuild: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-5px)' },
                        },
                        wallGrow: {
                            '0%': { transform: 'scaleX(0)' },
                            '100%': { transform: 'scaleX(1)' },
                        },
                        modalEnter: {
                            '0%': { opacity: '0', transform: 'scale(0.95) translateY(-10px)' },
                            '100%': { opacity: '1', transform: 'scale(1) translateY(0)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        /* Masonry theme styling */
        .masonry-gradient {
            background: linear-gradient(135deg, #475569 0%, #334155 100%);
        }
        
        .dark .masonry-gradient {
            background: linear-gradient(135deg, #64748b 0%, #475569 100%);
        }
        
        /* Brick pattern background */
        .brick-pattern {
            background-image: 
                linear-gradient(90deg, 
                    rgba(71, 85, 105, 0.1) 0%, 
                    rgba(71, 85, 105, 0.1) 25%, 
                    transparent 25%, 
                    transparent 50%, 
                    rgba(71, 85, 105, 0.1) 50%, 
                    rgba(71, 85, 105, 0.1) 75%, 
                    transparent 75%, 
                    transparent 100%);
            background-size: 60px 30px;
        }
        
        .dark .brick-pattern {
            background-image: 
                linear-gradient(90deg, 
                    rgba(100, 116, 139, 0.1) 0%, 
                    rgba(100, 116, 139, 0.1) 25%, 
                    transparent 25%, 
                    transparent 50%, 
                    rgba(100, 116, 139, 0.1) 50%, 
                    rgba(100, 116, 139, 0.1) 75%, 
                    transparent 75%, 
                    transparent 100%);
            background-size: 60px 30px;
        }
        
        /* Masonry card effect */
        .masonry-card {
            border: 2px solid #cbd5e1;
            border-left: 6px solid #475569;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
        }
        
        .masonry-card:before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, transparent 0%, rgba(71, 85, 105, 0.05) 100%);
            z-index: 0;
        }
        
        .masonry-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px rgba(71, 85, 105, 0.15);
            border-color: #94a3b8;
        }
        
        .dark .masonry-card {
            border-color: #475569;
        }
        
        .dark .masonry-card:hover {
            box-shadow: 0 20px 50px rgba(100, 116, 139, 0.25);
            border-color: #64748b;
        }
        
        /* Mortar line effect */
        .mortar-line {
            position: relative;
        }
        
        .mortar-line:after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 10%;
            right: 10%;
            height: 2px;
            background: #cbd5e1;
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        
        .mortar-line:hover:after {
            transform: scaleX(1);
        }
        
        /* Stone texture */
        .stone-texture {
            background: 
                radial-gradient(circle at 20% 30%, rgba(71, 85, 105, 0.1) 0%, transparent 20%),
                radial-gradient(circle at 70% 60%, rgba(71, 85, 105, 0.1) 0%, transparent 20%),
                radial-gradient(circle at 40% 80%, rgba(71, 85, 105, 0.1) 0%, transparent 20%);
        }

        /* Modal styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: white;
            border-radius: 1rem;
            padding: 1.5rem;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            transform: translateY(20px) scale(0.95);
            transition: all 0.3s ease;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            margin: 1rem;
        }

        .dark .modal-content {
            background-color: #1f2937;
            color: #f3f4f6;
            border: 1px solid #374151;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0) scale(1);
        }

        .modal-body {
            margin-top: 1rem;
            line-height: 1.6;
            font-size: 0.95rem;
        }

        .modal-body p {
            margin-bottom: 1rem;
        }

        .modal-body ul {
            margin: 1rem 0;
            padding-left: 1.5rem;
        }

        .modal-body li {
            margin-bottom: 0.5rem;
        }

        .modal-footer {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        .dark .modal-footer {
            border-top-color: #374151;
        }

        /* Custom scrollbar for modal */
        .modal-content::-webkit-scrollbar {
            width: 6px;
        }

        .modal-content::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .modal-content::-webkit-scrollbar-thumb {
            background: #f97316;
            border-radius: 10px;
        }

        .dark .modal-content::-webkit-scrollbar-track {
            background: #374151;
        }

        .dark .modal-content::-webkit-scrollbar-thumb {
            background: #fb923c;
        }

        /* Ensure buttons are clickable */
        button, .cursor-pointer {
            cursor: pointer;
        }

        /* Header spacing fix */
        .main-content {
            padding-top: 5rem;
        }

        @media (min-width: 1024px) {
            .main-content {
                padding-top: 6rem;
            }
        }

        /* Button color override - Orange theme for all CTAs */
        .btn-estimate {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
            border: none !important;
            transition: all 0.3s ease;
        }
        
        .btn-estimate:hover {
            background: linear-gradient(135deg, #ea580c, #c2410c) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.4) !important;
        }
        
        .dark .btn-estimate {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }
        
        .dark .btn-estimate:hover {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
        }
        
        .btn-estimate i {
            color: white !important;
        }

        /* Orange theme for Start Project button */
        .btn-start-project {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
            border: none !important;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px -1px rgba(249, 115, 22, 0.3) !important;
        }
        
        .btn-start-project:hover {
            background: linear-gradient(135deg, #ea580c, #c2410c) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(249, 115, 22, 0.4) !important;
        }
        
        .dark .btn-start-project {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }
        
        .dark .btn-start-project:hover {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
        }

        /* Orange gradient for featured cards */
        .orange-gradient-card {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
        }
        
        .dark .orange-gradient-card {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }

        /* Orange text for highlights */
        .text-orange-highlight {
            color: #f97316 !important;
        }
        
        .dark .text-orange-highlight {
            color: #fb923c !important;
        }

        /* Orange border for cards */
        .border-orange-highlight {
            border-color: #f97316 !important;
        }
        
        .dark .border-orange-highlight {
            border-color: #fb923c !important;
        }

        /* Orange background for icons */
        .bg-orange-light {
            background-color: #fff7ed !important;
        }
        
        .dark .bg-orange-light {
            background-color: #7c2d12 !important;
        }

        /* Responsive typography */
        @media (max-width: 640px) {
            .hero-title {
                font-size: 1.75rem !important;
                line-height: 1.2 !important;
            }
            
            .section-title {
                font-size: 1.5rem !important;
            }
            
            .card-title {
                font-size: 1.1rem !important;
            }
        }
    </style>
</head>

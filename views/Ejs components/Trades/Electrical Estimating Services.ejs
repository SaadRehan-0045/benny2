<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Electrical Estimating Services - Benny Estimates</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        },
                        electric: {
                            50: '#f0f9ff',
                            100: '#e0f2fe',
                            200: '#bae6fd',
                            300: '#7dd3fc',
                            400: '#38bdf8',
                            500: '#0ea5e9',
                            600: '#0284c7',
                            700: '#0369a1',
                            800: '#075985',
                            900: '#0c4a6e',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-in-out',
                        'slide-up': 'slideUp 0.3s ease-out',
                        'spark': 'spark 2s infinite',
                        'float': 'float 3s ease-in-out infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' }
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' }
                        },
                        spark: {
                            '0%, 100%': { opacity: '1', transform: 'scale(1)' },
                            '50%': { opacity: '0.7', transform: 'scale(1.05)' },
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        * {
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
        }
        
        /* Electrical theme styling */
        .electric-gradient {
            background: linear-gradient(135deg, #0ea5e9 0%, #0369a1 100%);
        }
        
        .dark .electric-gradient {
            background: linear-gradient(135deg, #38bdf8 0%, #0284c7 100%);
        }
        
        .spark-border {
            position: relative;
            overflow: hidden;
        }
        
        .spark-border:before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, #0ea5e9, transparent);
            animation: sparkLine 3s infinite;
        }
        
        @keyframes sparkLine {
            0% { left: -100%; }
            100% { left: 100%; }
        }
        
        /* Electric card hover effect */
        .electric-card {
            border-left: 4px solid #0ea5e9;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .electric-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(14, 165, 233, 0.15);
        }
        
        .dark .electric-card:hover {
            box-shadow: 0 15px 40px rgba(14, 165, 233, 0.3);
        }
        
        /* Circuit pattern background */
        .circuit-bg {
            background-image: 
                radial-gradient(circle at 25% 25%, rgba(14, 165, 233, 0.1) 2px, transparent 2px),
                radial-gradient(circle at 75% 75%, rgba(14, 165, 233, 0.1) 2px, transparent 2px);
            background-size: 50px 50px;
        }

        /* Modal styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background-color: white;
            border-radius: 1rem;
            padding: 2rem;
            max-width: 600px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            transform: translateY(20px);
            transition: transform 0.3s ease;
        }

        .dark .modal-content {
            background-color: #1f2937;
            color: #f3f4f6;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0);
        }

        .modal-body {
            margin-top: 1rem;
            line-height: 1.6;
        }

        .modal-footer {
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        .dark .modal-footer {
            border-top-color: #374151;
        }

        /* Responsive text adjustments */
        @media (max-width: 640px) {
            .hero-title {
                font-size: 2rem !important;
                line-height: 1.2 !important;
            }
            .electric-card {
                padding: 1rem !important;
            }
        }

        /* Ensure buttons are clickable */
        button {
            cursor: pointer;
        }

        /* New button color - orange theme */
        .btn-upload {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
            color: white !important;
            border: none;
            transition: all 0.3s ease;
        }
        
        .btn-upload:hover {
            background: linear-gradient(135deg, #ea580c, #c2410c) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(249, 115, 22, 0.4) !important;
        }
        
        .dark .btn-upload {
            background: linear-gradient(135deg, #fb923c, #f97316) !important;
        }
        
        .dark .btn-upload:hover {
            background: linear-gradient(135deg, #f97316, #ea580c) !important;
        }

        /* Benefits cards with black/white detection */
        .benefit-card {
            background-color: #ffffff;
            border: 2px solid #e2e8f0;
            transition: all 0.3s ease;
        }
        
        .dark .benefit-card {
            background-color: #1f2937;
            border-color: #374151;
        }
        
        .benefit-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border-color: #f97316;
        }
        
        .benefit-title {
            color: #0f172a !important;
            font-weight: 700;
        }
        
        .dark .benefit-title {
            color: #f8fafc !important;
        }
        
        .benefit-text {
            color: #334155 !important;
        }
        
        .dark .benefit-text {
            color: #cbd5e1 !important;
        }

        /* Force Tailwind colors to apply */
        .text-electric-600 {
            color: #0284c7 !important;
        }
        .dark .text-electric-400 {
            color: #38bdf8 !important;
        }
        .bg-electric-600 {
            background-color: #0284c7 !important;
        }
        .bg-electric-600:hover {
            background-color: #0369a1 !important;
        }
        .bg-electric-100 {
            background-color: #e0f2fe !important;
        }
        .dark .bg-electric-900 {
            background-color: #0c4a6e !important;
        }
    </style>
</head>

            const modalBody = document.getElementById('modalBody');
            
            const service = serviceData[serviceId];
            if (service) {
                modalTitle.textContent = service.title;
                modalBody.innerHTML = service.content;
                modalOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            } else {
                console.error('Service not found:', serviceId);
            }
        }

        // Close modal function
        window.closeModal = function() {
            const modalOverlay = document.getElementById('modalOverlay');
            modalOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close modal on outside click
        window.closeModalOnOutsideClick = function(event) {
            if (event.target === document.getElementById('modalOverlay')) {
                closeModal();
            }
        }

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeModal();
            }
        });

        // Theme functionality - wait for DOM to be fully loaded
        document.addEventListener('DOMContentLoaded', function() {
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = document.getElementById('themeIcon');
            const themeText = document.getElementById('themeText');
            
            // Check for saved theme preference or use default
            const savedTheme = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const currentTheme = savedTheme || (prefersDark ? 'dark' : 'light');
            
            // Apply theme on page load
            function applyTheme(theme) {
                if (theme === 'dark') {
                    document.documentElement.classList.add('dark');
                    updateThemeUI('dark', themeIcon, themeText);
                    console.log('Applied Dark Theme');
                } else {
                    document.documentElement.classList.remove('dark');
                    updateThemeUI('light', themeIcon, themeText);
                    console.log('Applied Light Theme');
                }
            }
            
            // Apply the theme immediately
            applyTheme(currentTheme);
            
            // Update theme UI elements
            function updateThemeUI(theme, themeIcon, themeText) {
                if (themeIcon && themeText) {
                    if (theme === 'dark') {
                        themeIcon.className = 'ri-sun-line mr-2';
                        themeText.textContent = 'Light';
                    } else {
                        themeIcon.className = 'ri-moon-line mr-2';
                        themeText.textContent = 'Dark';
                    }
                }
            }
            
            // Toggle theme function
            window.toggleTheme = function() {
                const isDark = document.documentElement.classList.contains('dark');
                
                if (isDark) {
                    // Switch to Light Mode
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                    updateThemeUI('light', themeIcon, themeText);
                    console.log('Switched to Light Mode');
                } else {
                    // Switch to Dark Mode
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                    updateThemeUI('dark', themeIcon, themeText);
                    console.log('Switched to Dark Mode');
                }
                
                // Force a reflow to ensure transitions work
                document.body.offsetHeight;
            }
            
            // Add event listener for theme toggle
            if (themeToggle) {
                themeToggle.addEventListener('click', toggleTheme);
            }
            
            // Listen for system theme changes
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
                if (!localStorage.getItem('theme')) {
                    const newTheme = e.matches ? 'dark' : 'light';
                    applyTheme(newTheme);
                    console.log('System theme changed to:', newTheme);
                }
            });
            
            console.log('Theme system initialized');
        });

        // Add electrical spark effects
        document.querySelectorAll('.animate-spark').forEach(element => {
            setInterval(() => {
                element.classList.add('spark');
                setTimeout(() => {
                    element.classList.remove('spark');
                }, 2000);
            }, 4000);
        });
        
        // Add hover effects to electric cards
        document.querySelectorAll('.electric-card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-8px)';
                this.style.boxShadow = '0 20px 50px rgba(14, 165, 233, 0.2)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(-5px)';
                this.style.boxShadow = '0 15px 40px rgba(14, 165, 233, 0.15)';
            });
        });
        
        console.log('Electrical Estimating Page Loaded');
        console.log('Script loaded successfully');
    </script>
</body>
</html>
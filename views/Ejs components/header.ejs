    <script>
        // Global theme and mobile drawer functionality for all .ejs files
        (function() {
            'use strict';

            // ========== THEME FUNCTIONALITY ==========
            function initTheme() {
                // Check for saved theme preference or use default
                const savedTheme = localStorage.getItem('theme');
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                const currentTheme = savedTheme || (prefersDark ? 'dark' : 'light');
                
                // Apply theme on page load
                if (currentTheme === 'dark') {
                    document.documentElement.classList.add('dark');
                    updateThemeUI('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                    updateThemeUI('light');
                }
            }
            
            // Update theme UI elements
            function updateThemeUI(theme) {
                const themeIconDesktop = document.getElementById('themeIconDesktop');
                const themeIconMobile = document.getElementById('themeIconMobile');
                const themeTextDesktop = document.getElementById('themeTextDesktop');
                
                if (themeIconDesktop) {
                    themeIconDesktop.className = theme === 'dark' ? 'ri-sun-line mr-2' : 'ri-moon-line mr-2';
                }
                if (themeIconMobile) {
                    themeIconMobile.className = theme === 'dark' ? 'ri-sun-line' : 'ri-moon-line';
                }
                if (themeTextDesktop) {
                    themeTextDesktop.textContent = theme === 'dark' ? 'Light' : 'Dark';
                }
            }
            
            // Toggle theme function - GLOBAL
            window.toggleTheme = function() {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                    updateThemeUI('light');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                    updateThemeUI('dark');
                }
            };

            // ========== MOBILE DRAWER FUNCTIONALITY ==========
            
            // Close drawer function
            window.closeMobileDrawer = function() {
                const mobileDrawer = document.getElementById('mobileDrawer');
                if (mobileDrawer) {
                    mobileDrawer.classList.remove('mobile-drawer-enter');
                    mobileDrawer.classList.add('mobile-drawer-exit');
                    setTimeout(() => {
                        mobileDrawer.classList.add('hidden');
                        mobileDrawer.classList.remove('mobile-drawer-exit');
                    }, 300);
                }
            };

            // Mobile dropdown toggle - GLOBAL
            window.toggleMobileDropdown = function(dropdownId) {
                const dropdown = document.getElementById(dropdownId + 'Dropdown');
                const arrow = document.getElementById(dropdownId + 'Arrow');
                
                if (!dropdown || !arrow) return;
                
                if (dropdown.classList.contains('hidden')) {
                    dropdown.classList.remove('hidden');
                    arrow.classList.remove('ri-arrow-down-s-line');
                    arrow.classList.add('ri-arrow-up-s-line');
                } else {
                    dropdown.classList.add('hidden');
                    arrow.classList.remove('ri-arrow-up-s-line');
                    arrow.classList.add('ri-arrow-down-s-line');
                }
            };

            // Initialize mobile drawer event listeners
            function initMobileDrawer() {
                // Use event delegation for drawer controls
                document.addEventListener('click', function(e) {
                    const mobileDrawer = document.getElementById('mobileDrawer');
                    
                    // Open drawer
                    if (e.target.closest('#mobileMenuButton')) {
                        e.preventDefault();
                        if (mobileDrawer) {
                            mobileDrawer.classList.remove('hidden');
                            mobileDrawer.classList.add('mobile-drawer-enter');
                        }
                        return;
                    }
                    
                    // Close drawer
                    if (e.target.closest('#closeDrawer') || e.target === mobileDrawer) {
                        e.preventDefault();
                        window.closeMobileDrawer();
                        return;
                    }
                });
                
                // Close drawer when clicking escape key
                document.addEventListener('keydown', function(e) {
                    if (e.key === 'Escape') {
                        window.closeMobileDrawer();
                    }
                });
            }

            // ========== EVENT LISTENERS FOR THEME TOGGLES ==========
            function initThemeToggles() {
                document.addEventListener('click', function(e) {
                    // Check if clicked element is theme toggle or its child
                    if (e.target.closest('#themeToggleDesktop') || e.target.closest('#themeToggleMobile')) {
                        e.preventDefault();
                        window.toggleTheme();
                    }
                });
            }

            // ========== INITIALIZE EVERYTHING ON DOM LOAD ==========
            document.addEventListener('DOMContentLoaded', function() {
                initTheme();
                initThemeToggles();
                initMobileDrawer();
                
                // Initialize all dropdowns as hidden
                const dropdowns = ['aboutMobile', 'servicesMobile', 'tradesMobile', 'blogsMobile'];
                dropdowns.forEach(function(id) {
                    const dropdown = document.getElementById(id + 'Dropdown');
                    const arrow = document.getElementById(id + 'Arrow');
                    if (dropdown) dropdown.classList.add('hidden');
                    if (arrow) {
                        arrow.classList.remove('ri-arrow-up-s-line');
                        arrow.classList.add('ri-arrow-down-s-line');
                    }
                });
            });

            // ========== RE-INITIALIZE FOR DYNAMIC CONTENT ==========
            window.reinitializeComponents = function() {
                initTheme();
                initThemeToggles();
                initMobileDrawer();
            };

        })();
    </script>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Benny Estimates</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-in-out',
                        'slide-in': 'slideIn 0.3s ease-out',
                        'slide-out': 'slideOut 0.3s ease-in',
                        'pulse-slow': 'pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideIn: {
                            '0%': { transform: 'translateX(-100%)', opacity: '0' },
                            '100%': { transform: 'translateX(0)', opacity: '1' },
                        },
                        slideOut: {
                            '0%': { transform: 'translateX(0)', opacity: '1' },
                            '100%': { transform: 'translateX(-100%)', opacity: '0' },
                        },
                    }
                }
            }
        }
    </script>
    <style>
        /* Hide scrollbars */
        * {
            scrollbar-width: none;
            -ms-overflow-style: none;
        }
        *::-webkit-scrollbar {
            display: none;
        }
        
        /* Theme transition for all elements */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, fill 0.3s ease, stroke 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        /* Better dark mode contrast */
        .dark body {
            color-scheme: dark;
        }
        
        /* Mobile drawer */
        .mobile-drawer-enter {
            animation: slideIn 0.3s ease-out forwards;
        }
        
        .mobile-drawer-exit {
            animation: slideOut 0.3s ease-in forwards;
        }

        /* Header with background image - MATCHING FILE#1 STYLE */
        .header-with-bg {
            position: relative;
            background-image: url('https://plus.unsplash.com/premium_photo-1682148775503-4f69d8aaf715?q=80&w=1171&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }
        
        /* Overlay - MATCHING FILE#1 STYLE */
        .header-with-bg::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.85) 0%, rgba(30, 41, 59, 0.9) 100%);
            z-index: 1;
            pointer-events: none;
        }
        
        .dark .header-with-bg::before {
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.85) 0%, rgba(15, 23, 42, 0.9) 100%);
        }
        
        /* Ensure content appears above overlay */
        .header-content {
            position: relative;
            z-index: 2;
        }

        /* Card background with transparency - MATCHING FILE#1 */
        .header-card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.2);
        }
        
        .dark .header-card {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        /* Text colors - MATCHING FILE#1 */
        .header-heading {
            color: white;
            font-weight: 700;
            letter-spacing: -0.02em;
        }
        
        .dark .header-heading {
            color: #f1f5f9;
        }
        
        .header-text {
            color: rgba(255, 255, 255, 0.9);
        }
        
        .dark .header-text {
            color: rgba(255, 255, 255, 0.8);
        }
        
        .header-link {
            color: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
        }
        
        .header-link:hover {
            color: #60a5fa;
            padding-left: 0.5rem;
        }
        
        .dark .header-link {
            color: rgba(255, 255, 255, 0.7);
        }
        
        .dark .header-link:hover {
            color: #93c5fd;
        }
        
        /* Nav link styling - MATCHING FILE#1 */
        .nav-link {
            font-weight: 500;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
            color: rgba(255, 255, 255, 0.9) !important;
            transition: all 0.3s ease;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
        }
        
        .nav-link:hover {
            color: #60a5fa !important;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
        }
        
        .dark .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
        }
        
        .dark .nav-link:hover {
            color: #93c5fd !important;
            background: rgba(255, 255, 255, 0.1);
        }
        
        /* Icon backgrounds - MATCHING FILE#1 */
        .icon-bg {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            transition: all 0.3s ease;
        }
        
        .icon-bg:hover {
            background: #60a5fa;
            border-color: #60a5fa;
            transform: translateY(-2px);
        }
        
        .dark .icon-bg {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }
        
        .dark .icon-bg:hover {
            background: #93c5fd;
            border-color: #93c5fd;
        }
        
        /* Top bar - MATCHING FILE#1 */
        .top-bar {
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
        }
        
        .dark .top-bar {
            background: rgba(0, 0, 0, 0.3);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        /* Contact icon - MATCHING FILE#1 */
        .contact-icon {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            transition: all 0.3s ease;
        }
        
        .contact-icon:hover {
            background: #60a5fa;
            transform: translateY(-2px);
        }
        
        .dark .contact-icon {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }
        
        .dark .contact-icon:hover {
            background: #93c5fd;
        }

        /* Clickable contact styles - MATCHING FILE#1 */
        .contact-link {
            color: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
            padding: 0.25rem 0.5rem;
            border-radius: 0.5rem;
        }
        
        .contact-link:hover {
            color: #60a5fa;
            background: rgba(255, 255, 255, 0.1);
            transform: translateX(5px);
        }
        
        .dark .contact-link:hover {
            color: #93c5fd;
            background: rgba(255, 255, 255, 0.1);
        }

        /* Discount Top Bar - MATCHING FILE#1 - FIXED to show only one offer on desktop */
        .discount-top-bar {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: white;
            text-align: center;
            padding: 0.5rem 0;
            font-weight: 700;
            font-size: 1.1rem;
            letter-spacing: 1px;
            box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);
            position: relative;
            z-index: 40;
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .dark .discount-top-bar {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
        }
        
        .discount-top-bar i {
            margin-right: 0.5rem;
            font-size: 1.2rem;
            animation: pulse-slow 2s infinite;
        }
        
        .discount-top-bar .claim-badge {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(5px);
            padding: 0.2rem 1rem;
            border-radius: 50px;
            margin-left: 0.5rem;
            font-size: 1.2rem;
            display: inline-block;
            font-weight: 800;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        /* Desktop offer - visible only on desktop */
        .desktop-offer {
            display: inline;
        }
        
        /* Mobile offer - visible only on mobile */
        .mobile-offer {
            display: none;
        }
        
        @media (max-width: 1023px) {
            .desktop-offer {
                display: none;
            }
            .mobile-offer {
                display: inline;
            }
            .discount-top-bar {
                font-size: 0.9rem;
                padding: 0.35rem 0;
            }
            .discount-top-bar .claim-badge {
                font-size: 0.9rem;
                padding: 0.1rem 0.8rem;
            }
        }

        /* Logo gradient - MATCHING FILE#1 */
        .logo-gradient {
            background: linear-gradient(135deg, #60a5fa, #93c5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .dark .logo-gradient {
            background: linear-gradient(135deg, #60a5fa, #93c5fd);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Dropdown menu - MATCHING FILE#1 with FIXED text color for light mode */
        .dropdown-menu {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 0, 0, 0.1);
            box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.2);
        }
        
        .dark .dropdown-menu {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        .dropdown-item {
            color: #1e293b !important; /* Dark text for light mode */
            transition: all 0.3s ease;
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
            font-weight: 500;
        }
        
        .dropdown-item:hover {
            background: rgba(59, 130, 246, 0.1);
            color: #2563eb !important;
            padding-left: 1.5rem;
        }
        
        .dropdown-item:last-child {
            border-bottom: none;
        }
        
        .dark .dropdown-item {
            color: rgba(255, 255, 255, 0.9) !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .dark .dropdown-item:hover {
            background: rgba(96, 165, 250, 0.2);
            color: #93c5fd !important;
        }

        /* Mobile dropdown items - FIXED text color for light mode */
        .mobile-dropdown-item {
            color: #1e293b !important;
            transition: all 0.3s ease;
        }
        
        .mobile-dropdown-item:hover {
            color: #2563eb !important;
            background: rgba(59, 130, 246, 0.1);
        }
        
        .dark .mobile-dropdown-item {
            color: rgba(255, 255, 255, 0.8) !important;
        }
        
        .dark .mobile-dropdown-item:hover {
            color: #93c5fd !important;
            background: rgba(96, 165, 250, 0.2);
        }

        /* Mobile specific adjustments */
        @media (max-width: 640px) {
            .mobile-top-bar {
                flex-wrap: nowrap;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                padding: 0.5rem 0.25rem;
                gap: 0.5rem;
            }
            
            .mobile-top-bar a {
                font-size: 0.7rem;
                white-space: nowrap;
                padding: 0.15rem 0.3rem;
            }
            
            .mobile-top-bar i {
                font-size: 0.8rem;
            }
            
            .mobile-top-bar .email-text {
                max-width: 120px;
                overflow: hidden;
                text-overflow: ellipsis;
            }
        }

        /* Award badge - MATCHING FILE#1 */
        .award-badge {
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            color: #1e293b;
            padding: 0.25rem 1rem;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.8rem;
            display: inline-block;
            letter-spacing: 0.5px;
        }
        
        .dark .award-badge {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: #0f172a;
        }

        /* Stats styling - MATCHING FILE#1 */
        .stat-number {
            font-size: 2rem;
            font-weight: 800;
            color: #60a5fa;
            line-height: 1;
        }
        
        .dark .stat-number {
            color: #93c5fd;
        }
        
        .stat-label {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.8);
            font-weight: 500;
        }
    </style>
</head>

   <script>
    // Article data for modal content
    const articleData = {
        1: {
            title: "Get Your Free Estimate",
            content: `<p class="mb-4">Ready to get started with your construction estimate? Our team of expert estimators is here to help you with accurate, detailed cost estimates for your project.</p>
            <p class="mb-4">Simply upload your plans, blueprints, or drawings through the form on this page, and we'll provide you with a comprehensive analysis of your project costs within 24-48 hours.</p>
            <p class="mb-4">Our estimates include detailed breakdowns of material quantities, labor costs, equipment needs, and contingency allowances, ensuring you have all the information needed to make informed decisions.</p>
            <p>Have questions before submitting? Feel free to contact us directly at <a href="mailto:Ben@bennyestimates.com" class="text-primary-600 dark:text-primary-400">Ben@bennyestimates.com</a> or call us at <a href="tel:+12898017224" class="text-primary-600 dark:text-primary-400">+1 (289) 801-7224</a>. We're here to help!</p>`
        }
    };

    // Open modal function
    window.openModal = function(articleId) {
        const modalOverlay = document.getElementById('modalOverlay');
        const modalTitle = document.getElementById('modalTitle');
        const modalBody = document.getElementById('modalBody');
        
        const article = articleData[articleId];
        if (article) {
            modalTitle.textContent = article.title;
            modalBody.innerHTML = article.content;
            modalOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
    }

    // Close modal function
    window.closeModal = function() {
        const modalOverlay = document.getElementById('modalOverlay');
        modalOverlay.classList.remove('active');
        document.body.style.overflow = '';
    }

    // Close modal on outside click
    window.closeModalOnOutsideClick = function(event) {
        if (event.target === document.getElementById('modalOverlay')) {
            closeModal();
        }
    }

    // Close modal with Escape key
    document.addEventListener('keydown', function(event) {
        if (event.key === 'Escape') {
            closeModal();
        }
    });

    // Theme functionality
    document.addEventListener('DOMContentLoaded', function() {
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        const themeText = document.getElementById('themeText');
        
        // Check for saved theme preference
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const currentTheme = savedTheme || (prefersDark ? 'dark' : 'light');
        
        // Apply theme on page load
        if (currentTheme === 'dark') {
            document.documentElement.classList.add('dark');
            if (themeIcon && themeText) updateThemeUI('dark', themeIcon, themeText);
        } else {
            document.documentElement.classList.remove('dark');
            if (themeIcon && themeText) updateThemeUI('light', themeIcon, themeText);
        }
        
        // Add event listener for theme toggle
        if (themeToggle) {
            themeToggle.addEventListener('click', function() {
                toggleTheme(themeIcon, themeText);
            });
        }

        // Initialize file upload functionality
        initFileUpload();
    });

    // Update theme UI elements
    function updateThemeUI(theme, themeIcon, themeText) {
        if (theme === 'dark') {
            themeIcon.className = 'ri-sun-line mr-2';
            themeText.textContent = 'Light Mode';
        } else {
            themeIcon.className = 'ri-moon-line mr-2';
            themeText.textContent = 'Dark Mode';
        }
    }
    
    // Toggle theme function
    function toggleTheme(themeIcon, themeText) {
        if (document.documentElement.classList.contains('dark')) {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('theme', 'light');
            updateThemeUI('light', themeIcon, themeText);
        } else {
            document.documentElement.classList.add('dark');
            localStorage.setItem('theme', 'dark');
            updateThemeUI('dark', themeIcon, themeText);
        }
    }

    // File upload functionality
    function initFileUpload() {
        const fileUpload = document.getElementById('fileUpload');
        const uploadArea = document.getElementById('uploadArea');
        const fileList = document.getElementById('fileList');
        
        if (uploadArea && fileUpload) {
            // Remove existing event listeners by cloning and replacing
            const newUploadArea = uploadArea.cloneNode(true);
            uploadArea.parentNode.replaceChild(newUploadArea, uploadArea);
            
            // Re-assign variables with new elements
            const updatedUploadArea = document.getElementById('uploadArea');
            const updatedFileUpload = document.getElementById('fileUpload');
            const updatedFileList = document.getElementById('fileList');
            
            updatedUploadArea.addEventListener('click', () => {
                updatedFileUpload.click();
            });
            
            updatedFileUpload.addEventListener('change', function() {
                handleFileSelection(this, updatedUploadArea, updatedFileList);
            });
            
            // Drag and drop functionality
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                updatedUploadArea.addEventListener(eventName, preventDefaults, false);
            });
            
            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }
            
            ['dragenter', 'dragover'].forEach(eventName => {
                updatedUploadArea.addEventListener(eventName, highlight, false);
            });
            
            ['dragleave', 'drop'].forEach(eventName => {
                updatedUploadArea.addEventListener(eventName, unhighlight, false);
            });
            
            function highlight() {
                updatedUploadArea.classList.add('border-primary-500', 'dark:border-primary-400');
                updatedUploadArea.classList.remove('border-gray-300', 'dark:border-gray-600');
            }
            
            function unhighlight() {
                updatedUploadArea.classList.remove('border-primary-500', 'dark:border-primary-400');
                updatedUploadArea.classList.add('border-gray-300', 'dark:border-gray-600');
            }
            
            updatedUploadArea.addEventListener('drop', function(e) {
                handleDrop(e, updatedFileUpload, updatedUploadArea, updatedFileList);
            }, false);
        }
    }

    function handleFileSelection(input, uploadArea, fileList) {
        if (input.files.length > 0) {
            const files = Array.from(input.files);
            let fileNames = '';
            let totalSize = 0;
            let hasValidFiles = true;

            // Allowed file types
            const allowedTypes = ['.pdf', '.dwg', '.rvt', '.jpg', '.jpeg', '.png'];
            
            files.forEach(file => {
                const fileExt = '.' + file.name.split('.').pop().toLowerCase();
                const fileSizeKB = (file.size / 1024).toFixed(2);
                const fileSizeMB = (file.size / (1024 * 1024)).toFixed(2);
                totalSize += file.size;
                
                // Check file type
                if (!allowedTypes.includes(fileExt)) {
                    hasValidFiles = false;
                    fileNames += `<div class="flex items-center justify-between mt-1 text-red-500">
                        <span class="truncate max-w-xs">${file.name}</span>
                        <span class="text-xs ml-2">Invalid type</span>
                    </div>`;
                }
                // Check individual file size (max 5MB)
                else if (file.size > 5 * 1024 * 1024) {
                    hasValidFiles = false;
                    fileNames += `<div class="flex items-center justify-between mt-1 text-red-500">
                        <span class="truncate max-w-xs">${file.name}</span>
                        <span class="text-xs ml-2">${fileSizeMB} MB (too large)</span>
                    </div>`;
                } else {
                    fileNames += `<div class="flex items-center justify-between mt-1 text-gray-600 dark:text-gray-400">
                        <span class="truncate max-w-xs">${file.name}</span>
                        <span class="text-xs ml-2">${fileSizeKB} KB</span>
                    </div>`;
                }
            });

            // Check total file size (max 10MB total)
            const totalSizeMB = (totalSize / (1024 * 1024)).toFixed(2);
            
            if (totalSize > 10 * 1024 * 1024) {
                showNotification(`Total file size (${totalSizeMB}MB) exceeds 10MB limit`, 'error');
                input.value = '';
                resetUploadArea(uploadArea, fileList);
                return;
            }
            
            if (!hasValidFiles) {
                showNotification('Some files are invalid or too large. Max 5MB per file, only PDF, DWG, RVT, JPG, PNG allowed.', 'error');
            }

            // Update upload area display
            uploadArea.innerHTML = `
                <div class="w-16 h-16 mx-auto ${hasValidFiles ? 'bg-green-100 dark:bg-green-900' : 'bg-yellow-100 dark:bg-yellow-900'} rounded-full flex items-center justify-center mb-4">
                    <i class="ri-${hasValidFiles ? 'check' : 'error-warning'}-line text-${hasValidFiles ? 'green' : 'yellow'}-600 dark:text-${hasValidFiles ? 'green' : 'yellow'}-400 text-2xl"></i>
                </div>
                <p class="text-gray-600 dark:text-gray-300 mb-2 font-medium">${files.length} file(s) selected</p>
                <p class="text-gray-500 dark:text-gray-400 text-sm">Total: ${totalSizeMB} MB</p>
                <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Click to change files</p>
            `;
            
            fileList.innerHTML = fileNames;
        } else {
            resetUploadArea(uploadArea, fileList);
        }
    }

    function handleDrop(e, fileUpload, uploadArea, fileList) {
        const dt = e.dataTransfer;
        const files = dt.files;
        
        // Validate file types
        const validTypes = ['.pdf', '.dwg', '.rvt', '.jpg', '.jpeg', '.png'];
        let invalidFiles = [];
        
        Array.from(files).forEach(file => {
            const ext = '.' + file.name.split('.').pop().toLowerCase();
            if (!validTypes.includes(ext)) {
                invalidFiles.push(file.name);
            }
        });
        
        if (invalidFiles.length > 0) {
            showNotification(`Invalid file types: ${invalidFiles.join(', ')}. Only PDF, DWG, RVT, JPG, PNG allowed.`, 'error');
            return;
        }
        
        fileUpload.files = files;
        
        // Trigger change event
        handleFileSelection(fileUpload, uploadArea, fileList);
    }

    function resetUploadArea(uploadArea, fileList) {
        if (uploadArea) {
            uploadArea.innerHTML = `
                <div class="w-16 h-16 mx-auto bg-primary-100 dark:bg-primary-900 rounded-full flex items-center justify-center mb-4">
                    <i class="ri-upload-cloud-line text-primary-600 dark:text-primary-400 text-2xl"></i>
                </div>
                <p class="text-gray-600 dark:text-gray-300 mb-2">
                    Drag & drop your files or <span class="text-primary-600 dark:text-primary-400 cursor-pointer">browse</span>
                </p>
                <p class="text-gray-500 dark:text-gray-400 text-sm">
                    Supports: PDF, DWG, RVT, JPG, PNG (Max 5MB per file, 10MB total)
                </p>
            `;
        }
        if (fileList) {
            fileList.innerHTML = '';
        }
    }

    // Form submission handling
    const contactForm = document.getElementById('contactForm');
    if (contactForm) {
        contactForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            // Show loading state
            const submitBtn = document.getElementById('submitBtn');
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="ri-loader-4-line animate-spin mr-2"></i>Sending...';
            submitBtn.disabled = true;
            
            // Get form data
            const formData = new FormData();
            formData.append('name', document.getElementById('name').value);
            formData.append('company', document.getElementById('company').value);
            formData.append('email', document.getElementById('email').value);
            formData.append('phone', document.getElementById('phone').value);
            formData.append('subject', document.getElementById('subject').value);
            formData.append('message', document.getElementById('message').value);
            
            // Add files if any
            const fileInput = document.getElementById('fileUpload');
            let hasValidFiles = true;
            
            if (fileInput.files.length > 0) {
                // Validate files before sending
                const allowedTypes = ['.pdf', '.dwg', '.rvt', '.jpg', '.jpeg', '.png'];
                let totalSize = 0;
                
                for (let i = 0; i < fileInput.files.length; i++) {
                    const file = fileInput.files[i];
                    const fileExt = '.' + file.name.split('.').pop().toLowerCase();
                    totalSize += file.size;
                    
                    // Check file type
                    if (!allowedTypes.includes(fileExt)) {
                        hasValidFiles = false;
                        showNotification(`File "${file.name}" has invalid type. Only PDF, DWG, RVT, JPG, PNG allowed.`, 'error');
                        break;
                    }
                    
                    // Check individual file size (max 5MB)
                    if (file.size > 5 * 1024 * 1024) {
                        hasValidFiles = false;
                        showNotification(`File "${file.name}" is too large. Maximum size is 5MB.`, 'error');
                        break;
                    }
                }
                
                // Check total size (max 10MB total)
                if (hasValidFiles && totalSize > 10 * 1024 * 1024) {
                    hasValidFiles = false;
                    showNotification('Total file size cannot exceed 10MB', 'error');
                }
                
                // Add files to formData if valid
                if (hasValidFiles) {
                    for (let i = 0; i < fileInput.files.length; i++) {
                        formData.append('files', fileInput.files[i]);
                    }
                }
            }
            
            if (!hasValidFiles && fileInput.files.length > 0) {
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
                return;
            }
            
            // Set timeout for the request (30 seconds)
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 30000);
            
            try {
                console.log('Sending form data...', {
                    name: formData.get('name'),
                    email: formData.get('email'),
                    files: fileInput.files.length
                });
                
                // Send data to server
                const response = await fetch('/api/contact-us', {
                    method: 'POST',
                    body: formData,
                    signal: controller.signal
                });
                
                clearTimeout(timeoutId);
                
                // Check if response is OK
                if (!response.ok) {
                    if (response.status === 413) {
                        throw new Error('File too large. Please reduce file size.');
                    }
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const data = await response.json();
                console.log('Server response:', data);
                
                if (data.success) {
                    // Show success message
                    showNotification(data.message, 'success');
                    
                    // Reset form
                    contactForm.reset();
                    
                    // Reset file upload area
                    const uploadArea = document.getElementById('uploadArea');
                    const fileList = document.getElementById('fileList');
                    resetUploadArea(uploadArea, fileList);
                    
                    // Clear file input
                    fileInput.value = '';
                } else {
                    showNotification(data.message || 'Failed to send message. Please try again.', 'error');
                }
            } catch (error) {
                console.error('Error details:', error);
                
                if (error.name === 'AbortError') {
                    showNotification('Request timed out. Please try again with smaller files.', 'error');
                } else if (error.message.includes('413') || error.message.includes('too large')) {
                    showNotification('File too large. Please reduce file size or try without attachments.', 'error');
                } else {
                    showNotification('Network error. Please check your connection and try again.', 'error');
                }
            } finally {
                // Restore button state
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
            }
        });
    }

    // Notification function
    function showNotification(message, type) {
        // Remove any existing notifications
        const existingNotifications = document.querySelectorAll('.fixed.top-4.right-4');
        existingNotifications.forEach(notification => notification.remove());
        
        const notification = document.createElement('div');
        notification.className = `fixed top-4 right-4 px-6 py-4 rounded-lg shadow-lg z-50 animate-slide-up ${
            type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'
        }`;
        notification.innerHTML = `
            <div class="flex items-center">
                <i class="ri-${type === 'success' ? 'checkbox-circle' : 'error-warning'}-fill mr-3 text-xl"></i>
                <div>${message}</div>
            </div>
        `;
        
        document.body.appendChild(notification);
        
        // Remove notification after 5 seconds
        setTimeout(() => {
            if (notification.parentNode) {
                notification.remove();
            }
        }, 5000);
    }

    // Copy contact info to clipboard
    document.querySelectorAll('a[href^="mailto:"], a[href^="tel:"]').forEach(link => {
        link.addEventListener('click', function(e) {
            if (e.ctrlKey || e.metaKey) {
                e.preventDefault();
                const text = this.textContent.trim();
                navigator.clipboard.writeText(text).then(() => {
                    showNotification(`Copied ${text} to clipboard`, 'success');
                }).catch(() => {
                    showNotification('Failed to copy to clipboard', 'error');
                });
            }
        });
    });

    // Add console log for debugging
    console.log('Contact Us Page Loaded with updated file upload handling');
</script>
</body>
</html>
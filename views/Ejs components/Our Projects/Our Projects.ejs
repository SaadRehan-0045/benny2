    </div>

    <script>
        // Article data for modal content
        const projectData = {
            1: {
                title: "Construction Estimator Sydney - Residential High-Rise",
                content: `<p class="mb-4"><strong>Project:</strong> Residential High-Rise Development, Sydney</p>
                <p class="mb-4"><strong>Location:</strong> Sydney CBD, New South Wales, Australia</p>
                <p class="mb-4"><strong>Client:</strong> Sydney Property Developers</p>

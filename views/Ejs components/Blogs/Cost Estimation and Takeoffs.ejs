        // Open modal function - defined globally
        window.openModal = function(articleId) {
            console.log('Opening modal for article:', articleId);
            const modalOverlay = document.getElementById('modalOverlay');
            const modalTitle = document.getElementById('modalTitle');
            const modalBody = document.getElementById('modalBody');
            
            const article = articleData[articleId];
            if (article) {
                modalTitle.textContent = article.title;
                modalBody.innerHTML = article.content;
                modalOverlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            } else {
                console.error('Article not found:', articleId);
            }
        }

        // Close modal function
        window.closeModal = function() {
            const modalOverlay = document.getElementById('modalOverlay');
            modalOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        // Close modal on outside click
        window.closeModalOnOutsideClick = function(event) {
            if (event.target === document.getElementById('modalOverlay')) {
                closeModal();
            }
        }

        // Close modal with Escape key
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                closeModal();
            }
        });

        // Theme functionality - wait for DOM to be fully loaded
        document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM fully loaded');
            
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = document.getElementById('themeIcon');
            const themeText = document.getElementById('themeText');
            const themeIndicator = document.getElementById('themeIndicator');
            
            // Check for saved theme preference or use default
            const savedTheme = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const currentTheme = savedTheme || (prefersDark ? 'dark' : 'light');
            
            // Apply theme on page load
            if (currentTheme === 'dark') {
                document.documentElement.classList.add('dark');
                if (themeIcon && themeText) updateThemeUI('dark', themeIcon, themeText, themeIndicator);
            } else {
                document.documentElement.classList.remove('dark');
                if (themeIcon && themeText) updateThemeUI('light', themeIcon, themeText, themeIndicator);
            }
            
            // Add event listener for theme toggle if exists
            if (themeToggle) {
                themeToggle.addEventListener('click', function() {
                    toggleTheme(themeIcon, themeText, themeIndicator);
                });
            }
        });

        // Update theme UI elements
        function updateThemeUI(theme, themeIcon, themeText, themeIndicator) {
            if (theme === 'dark') {
                themeIcon.className = 'ri-sun-line mr-2';
                themeText.textContent = 'Light Mode';
                if (themeIndicator) themeIndicator.textContent = '☀️';
            } else {
                themeIcon.className = 'ri-moon-line mr-2';
                themeText.textContent = 'Dark Mode';
                if (themeIndicator) themeIndicator.textContent = '🌙';
            }
        }
        
        // Toggle theme function
        function toggleTheme(themeIcon, themeText, themeIndicator) {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
                updateThemeUI('light', themeIcon, themeText, themeIndicator);
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                updateThemeUI('dark', themeIcon, themeText, themeIndicator);
            }
        }

        console.log('Cost Estimation Page Loaded');
        console.log('Script loaded successfully');
    </script>
</body>
</html>
        .dark .process-step.active .bg-green-50 .text-gray-800 {
            color: #f3f4f6 !important;
        }
        
        .dark .process-step.active .bg-purple-50 {
            background-color: #581c87 !important;
        }
        
        .dark .process-step.active .bg-purple-50 .text-gray-700,
        .dark .process-step.active .bg-purple-50 .text-gray-800 {

            color: #93c5fd !important;
        }
        
        .process-step.active a.text-primary-600:hover {
            text-decoration: underline;
        }
        
        /* Section background */
        .process-bg {
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        }
        
        .dark .process-bg {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }
        
        /* Image overlay */
        .process-image-overlay {
            position: relative;
            background-image: url('https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?q=80&w=1170&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            border-radius: 1rem;
            overflow: hidden;
        }
        
        .process-image-overlay::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.85) 0%, rgba(30, 41, 59, 0.9) 100%);
            z-index: 1;
        }
        
        .dark .process-image-overlay::before {
            background: linear-gradient(135deg, rgba(0, 0, 0, 0.85) 0%, rgba(15, 23, 42, 0.9) 100%);
        }
        
        .process-image-content {
            position: relative;
            z-index: 2;
        }
        
        /* Step connector lines */
        .step-connector {
            position: relative;
        }
        
        .step-connector::after {
            content: '';
            position: absolute;
            left: 40px;
            top: 100%;
            width: 2px;
            height: 20px;
            background: #cbd5e1;
        }
        
        .dark .step-connector::after {
            background: #475569;
        }
        
        .step-connector:last-child::after {
            display: none;
        }
        
        /* Process content animation */
        .process-content {
            overflow: hidden;
            transition: max-height 0.3s ease-out, padding 0.3s ease-out;
            max-height: 0;
            padding-top: 0;
            padding-bottom: 0;
        }
        
        .process-content.open {
            max-height: 1000px; /* Large enough to contain content */
            padding-top: 1.5rem;
            padding-bottom: 1.5rem;
        }
        
        /* Icon rotation */
        .ri-arrow-down-s-line {
            transition: transform 0.3s ease;
        }
        
        .rotate-icon {
            transform: rotate(180deg);
        }
    </style>
</head>

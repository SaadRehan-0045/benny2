        }
        
        .dark .process-step.active .bg-orange-50 .text-gray-700,
        .dark .process-step.active .bg-orange-50 .text-gray-800 {
            color: #f3f4f6 !important;
        }
        
        .dark .process-step.active .bg-gray-50 {
            background-color: #374151 !important;
        }
        
        .dark .process-step.active .bg-gray-50 .text-gray-700,
        .dark .process-step.active .bg-gray-50 .text-gray-800 {
            color: #f3f4f6 !important;
        }
        
        /* Active state icon colors */
        .process-step.active .ri-arrow-down-s-line {
            color: #3b82f6 !important;
        }
        
        .dark .process-step.active .ri-arrow-down-s-line {
            color: #93c5fd !important;
        }
        

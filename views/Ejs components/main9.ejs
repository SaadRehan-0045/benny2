    <script>
        // Self-contained accordion functionality that works on any page
        (function() {
            'use strict';
            
            // Function to initialize accordion
            function initAccordion() {
                console.log('Initializing accordion...');
                
                // Get all process steps
                const processSteps = document.querySelectorAll('.process-step');
                
                if (processSteps.length === 0) {
                    console.log('No process steps found');
                    return;
                }
                
                // First, ensure all content starts closed (except first one)
                processSteps.forEach((step, index) => {
                    const content = step.querySelector('.process-content');
                    const icon = step.querySelector('.ri-arrow-down-s-line');
                    
                    if (content) {
                        if (index === 0) {
                            // Open first step by default
                            content.classList.add('open');
                            step.classList.add('active');
                            if (icon) icon.classList.add('rotate-icon');
                        } else {
                            // Close other steps
                            content.classList.remove('open');
                            step.classList.remove('active');
                            if (icon) icon.classList.remove('rotate-icon');
                        }
                    }
                });
                
                // Add click event to all toggle buttons
                document.querySelectorAll('.process-toggle').forEach(button => {
                    // Remove any existing event listeners
                    button.removeEventListener('click', handleToggleClick);
                    // Add new event listener
                    button.addEventListener('click', handleToggleClick);
                });
            }
            
            // Toggle click handler
            function handleToggleClick(event) {
                event.preventDefault();
                
                const button = event.currentTarget;
                const step = button.closest('.process-step');
                
                if (!step) return;
                
                const content = step.querySelector('.process-content');
                const icon = button.querySelector('.ri-arrow-down-s-line');
                
                if (!content) return;
                
                // Check if this step is already open
                const isOpen = content.classList.contains('open');
                
                // Close all steps
                document.querySelectorAll('.process-step').forEach(otherStep => {
                    const otherContent = otherStep.querySelector('.process-content');
                    const otherIcon = otherStep.querySelector('.ri-arrow-down-s-line');
                    
                    if (otherContent) {
                        otherContent.classList.remove('open');
                    }
                    otherStep.classList.remove('active');
                    if (otherIcon) {
                        otherIcon.classList.remove('rotate-icon');
                    }
                });
                
                // If it wasn't open, open it
                if (!isOpen) {
                    content.classList.add('open');
                    step.classList.add('active');
                    if (icon) {
                        icon.classList.add('rotate-icon');
                    }
                }
                
                // Scroll to the step smoothly (optional)
                step.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
            
            // Initialize on DOM load
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initAccordion);
            } else {
                // DOM is already loaded
                initAccordion();
            }
            
            // Re-initialize after any dynamic content changes
            // This can be called from outside if needed
            window.reinitAccordion = initAccordion;
            
        })();
    </script>

                        <div class="p-5 sm:p-6">
                            <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-3">
                                Lumber Takeoff Services
                            </h3>
                            <p class="text-gray-600 dark:text-gray-300 text-sm sm:text-base">
                                Detailed framing lumber, plywood, dimensional lumber, and engineered wood product takeoffs for residential and commercial framing.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Row 3 - Last 2 Services (centered) -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5 lg:gap-6">
                    <!-- Service 9: Thermal & Moisture Protection -->
                    <div class="service-card bg-white dark:bg-gray-800 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-indigo-300 dark:hover:border-indigo-600 hover:shadow-xl h-full flex flex-col lg:col-start-2">
                        <div class="image-container">
                            <img src="https://images.pexels.com/photos/280235/pexels-photo-280235.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&dpr=2" 
                                 alt="Roofing and insulation installation" 
                                 class="service-image"
                                 loading="lazy">
                        </div>
                        <div class="p-5 sm:p-6">
                            <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-3">
                                Thermal & Moisture Protection
                            </h3>
                            <p class="text-gray-600 dark:text-gray-300 text-sm sm:text-base">
                                Accurate roofing, insulation, waterproofing, and air barrier material takeoffs for building envelope protection systems.
                            </p>
                        </div>
                    </div>

                    <!-- Service 10: Interior & Exterior Finishes -->
                    <div class="service-card bg-white dark:bg-gray-800 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-purple-300 dark:hover:border-purple-600 hover:shadow-xl h-full flex flex-col">
                        <div class="image-container">
                            <img src="https://images.pexels.com/photos/1722183/pexels-photo-1722183.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&dpr=2" 
                                 alt="Interior painting and finishing work" 
                                 class="service-image"
                                 loading="lazy">
                        </div>
                        <div class="p-5 sm:p-6">
                            <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-3">
                                Interior & Exterior Finishes
                            </h3>
                            <p class="text-gray-600 dark:text-gray-300 text-sm sm:text-base">
                                Comprehensive drywall, painting, flooring, ceiling, and exterior cladding quantity takeoffs for complete finish work.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Simple Footer Note -->
           
        </div>
    </section>

    <script>
        // Theme functionality
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        const themeText = document.getElementById('themeText');
        
        // Check for saved theme preference or use default
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const currentTheme = savedTheme || (prefersDark ? 'dark' : 'light');
        
        // Apply theme on page load
        if (currentTheme === 'dark') {
            document.documentElement.classList.add('dark');
            if (updateThemeUI) updateThemeUI('dark');
        } else {
            document.documentElement.classList.remove('dark');
            if (updateThemeUI) updateThemeUI('light');
        }
        
        // Update theme UI elements
        function updateThemeUI(theme) {
            if (theme === 'dark') {
                if (themeIcon) themeIcon.className = 'ri-sun-line mr-2';
                if (themeText) themeText.textContent = 'Light Mode';
            } else {
                if (themeIcon) themeIcon.className = 'ri-moon-line mr-2';
                if (themeText) themeText.textContent = 'Dark Mode';
            }
        }
        
        // Toggle theme function
        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
                updateThemeUI('light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                updateThemeUI('dark');
            }
        }
        
        // Add event listener for theme toggle if exists
        if (themeToggle) {
            themeToggle.addEventListener('click', toggleTheme);
        }
        
        // Listen for system theme changes
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
            if (!localStorage.getItem('theme')) {
                if (e.matches) {
                    document.documentElement.classList.add('dark');
                    updateThemeUI('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                    updateThemeUI('light');
                }
            }
        });
    </script>
</body>
</html>
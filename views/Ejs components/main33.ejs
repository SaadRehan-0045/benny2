<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Benny Estimates - Specialized Services</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.5s ease-in-out',
                        'slide-up': 'slideUp 0.5s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(30px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme transition */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
        }
        
        /* Service card hover effects */
        .service-card {
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .service-card:hover {
            transform: translateY(-8px);
        }
        
        .service-card:hover .service-image {
            transform: scale(1.1);
        }
        
        /* Image container */
        .image-container {
            width: 100%;
            height: 160px;
            overflow: hidden;
            border-radius: 0.75rem;
            margin-bottom: 1rem;
        }
        
        .service-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        
        /* Gradient backgrounds */
        .services-gradient-bg {
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        }
        
        .dark .services-gradient-bg {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">
    
    <!-- Services Section -->
    <section class="services-gradient-bg py-12 lg:py-20 animate-fade-in">
        <div class="container mx-auto px-4">
            
           

            <!-- Simple "Our Services" Heading -->
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-bold text-gray-900 dark:text-white mb-12 text-center">
               Trades
            </h1>

            <!-- Services Grid - 10 cards in 3 rows (4+4+2) with images -->
            <div class="animate-slide-up">
                <!-- Row 1 - First 4 Services -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5 lg:gap-6 mb-4 sm:mb-5 lg:mb-6">
                    <!-- Service 1: Electrical Estimating Services -->
                    <div class="service-card bg-white dark:bg-gray-800 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-yellow-300 dark:hover:border-yellow-600 hover:shadow-xl h-full flex flex-col">
                        <div class="image-container">
                            <img src="https://images.pexels.com/photos/3825581/pexels-photo-3825581.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&dpr=2" 
                                 alt="Electrician working on electrical panel" 
                                 class="service-image"
                                 loading="lazy">
                        </div>
                        <div class="p-5 sm:p-6">
                            <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-3">
                                Electrical Estimating Services
                            </h3>
                            <p class="text-gray-600 dark:text-gray-300 text-sm sm:text-base">
                                Precise electrical quantity takeoffs, conduit and wire measurements, panel schedules, and fixture counts for residential and commercial projects.
                            </p>
                        </div>
                    </div>

                    <!-- Service 2: Concrete Estimating Services -->
                    <div class="service-card bg-white dark:bg-gray-800 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-gray-400 dark:hover:border-gray-500 hover:shadow-xl h-full flex flex-col">
                        <div class="image-container">
                            <img src="https://images.pexels.com/photos/1799799/pexels-photo-1799799.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&dpr=2" 
                                 alt="Concrete pouring and foundation work" 
                                 class="service-image"
                                 loading="lazy">
                        </div>
                        <div class="p-5 sm:p-6">
                            <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-3">
                                Concrete Estimating Services
                            </h3>
                            <p class="text-gray-600 dark:text-gray-300 text-sm sm:text-base">
                                Accurate concrete volume calculations, rebar quantities, formwork measurements, and foundation estimates for all types of structures.
                            </p>
                        </div>
                    </div>

                    <!-- Service 3: Opening Estimating Services -->
                    <div class="service-card bg-white dark:bg-gray-800 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 hover:shadow-xl h-full flex flex-col">
                        <div class="image-container">
                            <img src="https://images.pexels.com/photos/280232/pexels-photo-280232.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&dpr=2" 
                                 alt="Modern windows and doors installation" 
                                 class="service-image"
                                 loading="lazy">
                        </div>
                        <div class="p-5 sm:p-6">
                            <h3 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white mb-3">
                                Opening Estimating Services
                            </h3>
                            <p class="text-gray-600 dark:text-gray-300 text-sm sm:text-base">
                                Detailed door and window schedules, frame measurements, hardware takeoffs, and glass quantity calculations for commercial and residential projects.
                            </p>
                        </div>
                    </div>

                    <!-- Service 4: Masonry Estimating Services -->

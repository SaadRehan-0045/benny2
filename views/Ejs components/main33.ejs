                        </div>
                    </div>

                    <!-- Service 8: Lumber Takeoff Services -->
                    <div class="service-card bg-white dark:bg-gray-800 rounded-xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-orange-300 dark:hover:border-orange-600 hover:shadow-xl h-full flex flex-col">
                        <div class="image-container">
                            <img src="https://images.pexels.com/photos/129600/wood-lumber-timber-construction-129600.jpeg?auto=compress&cs=tinysrgb&w=600&h=400&dpr=2" 

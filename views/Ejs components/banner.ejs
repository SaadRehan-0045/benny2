    <!-- Main Content for context -->
    <div class="container mx-auto px-4 py-8 mt-4">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-6">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Demo Content</h2>
            <p class="text-gray-600 dark:text-gray-300 mb-6">
                This is a demonstration of the Top Contact Bar. In your actual website, this bar would appear 
                at the very top of the page, above the main navigation header.
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
                    <h3 class="font-bold text-gray-900 dark:text-white mb-2">Desktop View</h3>
                    <p class="text-gray-600 dark:text-gray-300 text-sm">
                        On desktop, all contact information and social media icons are displayed inline.
                    </p>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 p-4 rounded-lg">
